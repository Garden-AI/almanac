---
import Page from '../layouts/Page.astro';
import OrnamentRule from '../components/OrnamentRule.astro';

const sections = [
  {
    heading: 'What this is',
    body: [
      "TODO",
    ],
    dropCap: true,
  },
  {
    heading: "What this isn't",
    body: [
      "TODO"
    ],
  },
  {
    heading: 'How models are placed',
    body: [
      'TODO'
    ],
  },
  {
    heading: 'How installations are verified',
    body: [
      'TODO'
    ],
  },
  {
    heading: 'How the Almanac is maintained',
    body: [
      'TODO'
    ],
  },
];

const marginalia = [
  { label: 'Acknowledgement', body: 'TODO' },
  { label: 'Reference set', body: 'TODO' },
  { label: 'See also', body: 'TODO' },
];
---
<Page title="About — Garden's Almanac" section="About this Almanac" folioId="§01">
  <p class="sc" style="font-size: 12px; letter-spacing: 0.18em; color: var(--ink-2);">Section 01</p>
  <h1 style="margin-top: 3px;">About this Almanac</h1>
  <p class="it" style="margin-top: 5px; font-size: 14.5px; color: var(--ink-2);">
    What it is, what it isn't, and how it was made.
  </p>
  <div style="margin-top: 8px;"><OrnamentRule width={220} /></div>

  <div class="detail-body" style="margin-top: 14px;">
    <div style="font-size: 13px; line-height: 1.5;">
      {sections.map((s) => (
        <section style="margin-top: 12px;">
          <h3 class="sc" style="font-size: 11.5px; letter-spacing: 0.10em; margin-bottom: 4px; font-weight: 500;">
            {s.heading}
          </h3>
          {s.body.map((p, i) => (
            <p
              class={s.dropCap && i === 0 ? 'drop-cap' : undefined}
              style={`margin: ${i === 0 ? '0' : '8px 0 0'};`}
              set:html={p}
            />
          ))}
        </section>
      ))}
    </div>

    <aside class="detail-rail">
      {marginalia.map((m, i) => (
        <div class="margin" style={`padding-bottom: 10px; ${i < marginalia.length - 1 ? 'border-bottom: 0.5px solid var(--rule-soft); margin-bottom: 12px;' : ''}`}>
          <span class="label">{m.label}</span>
          <p class="it" style="margin: 0;" set:html={m.body} />
        </div>
      ))}
    </aside>
  </div>
</Page>
