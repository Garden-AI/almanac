---
import { getCollection } from 'astro:content';
import Page from '../../layouts/Page.astro';
import { getClusterManifest } from '../../lib/rootstock';

export async function getStaticPaths() {
  const clusters = await getCollection('clusters');
  return clusters.map((c) => ({ params: { slug: c.id }, props: { cluster: c } }));
}

const { cluster } = Astro.props;
const c = cluster.data;
const manifest = await getClusterManifest(cluster.id);

const models = await getCollection('models');
const supported = manifest
  ? models
      .filter((m) => manifest.environments[m.data.rootstockEnv])
      .map((m) => ({
        model: m,
        env: manifest.environments[m.data.rootstockEnv],
      }))
  : [];
---
<Page
  title={`${c.name} — Garden's Almanac`}
  section="§ Cluster"
  folioId={`/cluster/${cluster.id}`}
>
  <p class="sc" style="font-size: 11.5px; letter-spacing: 0.14em;">
    {c.institution}
  </p>
  <h1>{c.name}</h1>
  {c.subtitle && (
    <p class="it" style="color: var(--ink-2); font-size: 14px;">{c.subtitle}</p>
  )}
  <hr class="title-rule" />

  <div class="detail-body">
    <div>
      <h2 class="sc" style="font-size: 13px;">Specifications</h2>
      <table class="almanac" style="margin-top: 6px;">
        <tbody>
          {Object.entries(c.specs).map(([k, v]) => (
            <tr>
              <td>{k}</td>
              <td>
                {v.startsWith('http') ? <a class="ink-link" href={v}>{v}</a> : v}
              </td>
            </tr>
          ))}
        </tbody>
      </table>

      <h2 class="sc" style="font-size: 13px; margin-top: 22px;">Supported models</h2>
      {manifest ? (
        <>
          <p class="it" style="font-size: 12px; color: var(--ink-2); margin-top: 4px;">
            Live from Rootstock · last updated {manifest.last_updated.slice(0, 10)}
          </p>
          {supported.length > 0 ? (
            <table class="almanac" style="margin-top: 6px;">
              <thead>
                <tr><th>Model</th><th>Environment</th><th>Status</th><th>Built</th></tr>
              </thead>
              <tbody>
                {supported.map(({ model, env }) => (
                  <tr>
                    <td><a class="ink-link it" href={`/model/${model.id}`}>{model.data.name}</a></td>
                    <td class="mono">{model.data.rootstockEnv}</td>
                    <td>
                      {env.status === 'ready'
                        ? <span class="status-verified">●</span>
                        : <span class="status-stale">◐</span>}
                      {' '}{env.status}
                    </td>
                    <td class="mono">{env.built_at.slice(0, 10)}</td>
                  </tr>
                ))}
              </tbody>
            </table>
          ) : (
            <p class="it" style="color: var(--ink-2);">
              No catalog model declares an environment served on this cluster.
            </p>
          )}

          <details style="margin-top: 14px;">
            <summary class="sc" style="cursor: pointer; font-size: 11.5px;">
              All Rootstock environments on this cluster
            </summary>
            <table class="almanac" style="margin-top: 6px;">
              <thead><tr><th>Environment</th><th>Status</th><th>Built</th></tr></thead>
              <tbody>
                {Object.entries(manifest.environments).map(([name, env]) => (
                  <tr>
                    <td class="mono">{name}</td>
                    <td>{env.status}</td>
                    <td class="mono">{env.built_at.slice(0, 10)}</td>
                  </tr>
                ))}
              </tbody>
            </table>
          </details>
        </>
      ) : (
        <p class="it" style="color: var(--ink-2);">
          Rootstock has no manifest for <span class="mono">{cluster.id}</span>.
        </p>
      )}

      {c.runningOn && (
        <>
          <h2 class="sc" style="font-size: 13px; margin-top: 22px;">Running on {c.name}</h2>
          <div style="margin-top: 6px; white-space: pre-wrap;">{c.runningOn}</div>
        </>
      )}
    </div>

    <aside class="detail-rail">
      {c.notes && (
        <div class="margin">
          <span class="label">Notes</span>
          <p class="it">{c.notes}</p>
        </div>
      )}
    </aside>
  </div>
</Page>
