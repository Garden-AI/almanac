---
import { getCollection } from 'astro:content';
import Page from '../layouts/Page.astro';
import { getRootstockDump } from '../lib/rootstock';
import { url } from '../lib/url';

const clusters = (await getCollection('clusters')).sort((a, b) => {
  const oa = a.data.order ?? 999;
  const ob = b.data.order ?? 999;
  if (oa !== ob) return oa - ob;
  return a.data.name.localeCompare(b.data.name);
});

const models = (await getCollection('models')).sort((a, b) => {
  const fam = a.data.family.id.localeCompare(b.data.family.id);
  if (fam !== 0) return fam;
  const pa = parseFloat(a.data.params) * (a.data.params.endsWith('B') ? 1000 : 1);
  const pb = parseFloat(b.data.params) * (b.data.params.endsWith('B') ? 1000 : 1);
  return pb - pa;
});

const dump = await getRootstockDump();
const lastUpdated = dump.manifests
  .map((m) => m.last_updated)
  .sort()
  .at(-1);
const rootstockVersion = dump.manifests[0]?.rootstock_version;

const formatLastUpdated = (iso: string | undefined) => {
  if (!iso) return '—';
  const d = new Date(iso);
  const day = d.getUTCDate();
  const month = d.toLocaleString('en-US', { month: 'long', timeZone: 'UTC' });
  const year = d.getUTCFullYear();
  const hh = String(d.getUTCHours()).padStart(2, '0');
  const mm = String(d.getUTCMinutes()).padStart(2, '0');
  return `${day} ${month} ${year} · ${hh}:${mm} UTC`;
};

type CellState = 'verified' | 'lapsed' | 'na';

// WIREFRAME DATA: cell states are fabricated for presentation purposes.
// The Rootstock fixture currently only carries manifests for Della and Sophia,
// which would leave most of the matrix hatched. Replace this with the real
// stateFor() once the other clusters are onboarded:
//   const env = manifest?.environments[modelEnv];
//   if (!env) return 'na';
//   return env.status === 'ready' ? 'verified' : 'lapsed';
const djb2 = (s: string): number => {
  let h = 5381;
  for (let i = 0; i < s.length; i++) h = (((h << 5) + h) ^ s.charCodeAt(i)) >>> 0;
  return h;
};
const wireframeState = (modelId: string, clusterSlug: string): CellState => {
  const r = djb2(`${modelId}/${clusterSlug}`) % 100;
  // Frontier runs AMD/ROCm; only ACE-style and a few message-passing models port cleanly.
  if (clusterSlug === 'frontier') {
    if (r < 30) return 'verified';
    if (r < 38) return 'lapsed';
    return 'na';
  }
  // Della carries a tighter env set than the leadership facilities.
  if (clusterSlug === 'della') {
    if (r < 70) return 'verified';
    if (r < 82) return 'lapsed';
    return 'na';
  }
  // Polaris, Perlmutter, Delta, Sophia: broad coverage, occasional lapsed.
  if (r < 84) return 'verified';
  if (r < 92) return 'lapsed';
  return 'na';
};

let counts = { verified: 0, lapsed: 0, na: 0 };
const grid = models.map((m) => ({
  model: m,
  cells: clusters.map((c) => {
    const state = wireframeState(m.id, c.id);
    counts[state]++;
    return { cluster: c, state };
  }),
}));

const codeSnippet = `from ase.build import bulk
from rootstock import RootstockCalculator

atoms = bulk("Cu", "fcc", a=3.6) * (5, 5, 5)

with RootstockCalculator(
  cluster="della", 
  model="mace", 
  checkpoint="medium", 
  device="cuda"
) as calc:
    atoms.calc = calc
    print(atoms.get_potential_energy())`;
---
<Page
  title="The Compatibility Matrix — Garden's Almanac"
  section="The Compatibility Matrix"
  folioId="§ Pull-out"
  wide
>
  <style>
    .matrix-table { table-layout: fixed; }
    .matrix-table th.cluster-h { text-align: center; vertical-align: bottom; padding: 6px 4px; line-height: 1.2; }
    .matrix-table td.cell { text-align: center; padding: 4px 0; }
    .howto pre {
      margin: 4px 0 0;
      font-family: var(--mono);
      font-size: 9.75px;
      line-height: 1.4;
      padding: 5px 8px;
      overflow-x: auto;
      white-space: pre;
      background: rgba(26, 22, 18, 0.035);
      border: 0.5px solid var(--rule);
    }
  </style>

  <div style="display: grid; grid-template-columns: 1fr 460px; gap: 28px; align-items: start;">
    <div>
      <p class="sc" style="font-size: 11.5px; letter-spacing: 0.14em; color: var(--ink-2);">Pull-out reference</p>
      <h1 style="font-size: 36px; margin-top: 2px; line-height: 1;">The Availability Matrix</h1>
      <p class="it" style="color: var(--ink-2); font-size: 12.75px; margin-top: 4px; max-width: 720px; line-height: 1.4;">
        A filled circle means Rootstock tested the install and ran a basic inference within the last
        seven days. An open circle means that check has lapsed. Hatched cells are not supported.
      </p>
      <div style="font-size: 11px; color: var(--ink-2); white-space: nowrap; margin-top: 6px;">
        <span class="sc" style="font-size: 10px; letter-spacing: 0.10em; color: var(--ink);">Last updated</span>
        {' '}{formatLastUpdated(lastUpdated)}
        {rootstockVersion && (
          <>
            {' · '}<span class="mono" style="font-size: 10.5px;">nightly CI · rootstock {rootstockVersion}</span>
          </>
        )}
      </div>
    </div>

    <section class="howto" style="border-left: 0.5px solid var(--rule); padding-left: 18px;">
      <div class="sc" style="font-size: 11px; letter-spacing: 0.14em; color: var(--ink); margin-bottom: 3px;">
        How to use these models
      </div>
      <p style="margin: 0 0 4px; font-size: 11px; line-height: 1.4; color: var(--ink);">
        A filled circle means the model is ready to run with Rootstock
        on that cluster. Install the Rootstock Python library with pip or uv, and then use a
        {' '}<span class="mono" style="font-size: 10.5px;">RootstockCalculator</span>{' '}
        which plugs in wherever you use ASE calculators.
      </p>
      <pre>{codeSnippet}</pre>
      <div style="display: grid; grid-template-columns: auto 1fr; column-gap: 8px; row-gap: 1px; font-size: 10px; line-height: 1.35; color: var(--ink); margin-top: 5px;">
        <div class="sc" style="font-size: 9.5px; letter-spacing: 0.10em; color: var(--ink-2); align-self: start;">Further →</div>
        <div>
          <a class="ink-link it" href="https://garden-ai.github.io/rootstock/">Rootstock docs</a>
          <span style="color: var(--ink-2);"> — More details, including LAMMPS compatibility.</span>
        </div>
        <div></div>
        <div>
          <a class="ink-link it" href="https://gitlab.osti.gov/genesis/genesis-skills/-/tree/main/skills/modcon-skills">DOE agent skills</a>
          <span style="color: var(--ink-2);"> — Add to your agents to run on DOE clusters.</span>
        </div>
        <div></div>
      </div>
    </section>
  </div>
  <hr class="double-rule" style="margin-top: 8px; margin-bottom: 8px;" />

  <div class="cm-tight">
    <table class="almanac matrix-table">
      <colgroup>
        <col style="width: 24px;" />
        <col style="width: 160px;" />
        <col style="width: 60px;" />
        {clusters.map(() => <col />)}
        <col />
      </colgroup>
      <thead>
        <tr>
          <th>№</th>
          <th>Model</th>
          <th style="text-align: right;">Size</th>
          {clusters.map((c) => (
            <th class="cluster-h">
              <div style="font-family: var(--smallcaps); font-size: 12.5px; letter-spacing: 0.06em;">
                <a class="ink-link" href={url(`/cluster/${c.id}`)}>{c.data.name}</a>
              </div>
              <div class="sc" style="font-size: 9.5px; letter-spacing: 0.10em; color: var(--ink-2);">
                {c.data.institutionShort ?? c.data.institution.split('·')[0].trim()}
              </div>
              <div class="mono" style="font-size: 9px; color: var(--ink-3); letter-spacing: 0.02em;">
                {c.data.gpu ?? '—'}
              </div>
            </th>
          ))}
          <th class="cluster-h">
            <div style="font-family: var(--smallcaps); font-size: 12.5px; letter-spacing: 0.06em; font-style: italic; color: var(--ink-3);">
              + more
            </div>
            <div class="sc" style="font-size: 9.5px; letter-spacing: 0.10em; color: var(--ink-2);">
              Coming soon
            </div>
            <div class="mono" style="font-size: 9px; color: var(--ink-3); letter-spacing: 0.02em;">—</div>
          </th>
        </tr>
      </thead>
      <tbody>
        {grid.map(({ model, cells }, i) => (
          <tr>
            <td style="font-variant-numeric: tabular-nums; color: var(--ink-2);">{String(i + 1).padStart(2, '0')}</td>
            <td><a class="ink-link" href={url(`/model/${model.id}`)} style="font-weight: 600;">{model.data.name}</a></td>
            <td style="text-align: right; font-variant-numeric: tabular-nums;">{model.data.params}</td>
            {cells.map(({ state }) => (
              <td class="cell">
                {state === 'verified' && (
                  <svg width="14" height="14" viewBox="0 0 14 14" aria-label="verified">
                    <circle cx="7" cy="7" r="3.6" fill="var(--oxblood)" />
                  </svg>
                )}
                {state === 'lapsed' && (
                  <svg width="14" height="14" viewBox="0 0 14 14" aria-label="lapsed">
                    <circle cx="7" cy="7" r="3.4" fill="none" stroke="var(--oxblood)" stroke-width="1" />
                  </svg>
                )}
                {state === 'na' && (
                  <svg width="100%" height="14" viewBox="0 0 40 14" preserveAspectRatio="none" aria-label="not applicable" style="display: block;">
                    <defs>
                      <pattern id="na-hatch" patternUnits="userSpaceOnUse" width="5" height="5" patternTransform="rotate(45)">
                        <line x1="0" y1="0" x2="0" y2="5" stroke="var(--ink)" stroke-width="0.5" opacity="0.35" />
                      </pattern>
                    </defs>
                    <rect x="0" y="3" width="40" height="8" fill="url(#na-hatch)" />
                  </svg>
                )}
              </td>
            ))}
            <td class="cell">
              <span style="color: var(--ink-3); opacity: 0.6; font-size: 12px;">·</span>
            </td>
          </tr>
        ))}
      </tbody>
    </table>

    <div style="display: flex; justify-content: space-between; align-items: baseline; margin-top: 8px; font-size: 11.5px;">
      <span class="it" style="color: var(--ink-2);">
        {models.length} models · {clusters.length} clusters · {counts.verified} verified, {counts.lapsed} lapsed, {counts.na} not applicable
      </span>
      <span style="display: inline-flex; align-items: center; gap: 14px;">
        <span style="display: inline-flex; align-items: center; gap: 6px;">
          <svg width="14" height="14" viewBox="0 0 14 14"><circle cx="7" cy="7" r="3.6" fill="var(--oxblood)" /></svg>
          <span class="sc" style="font-size: 10.5px; letter-spacing: 0.08em; color: var(--ink-2);">Verified</span>
        </span>
        <span style="display: inline-flex; align-items: center; gap: 6px;">
          <svg width="14" height="14" viewBox="0 0 14 14"><circle cx="7" cy="7" r="3.4" fill="none" stroke="var(--oxblood)" stroke-width="1" /></svg>
          <span class="sc" style="font-size: 10.5px; letter-spacing: 0.08em; color: var(--ink-2);">Lapsed</span>
        </span>
        <span style="display: inline-flex; align-items: center; gap: 6px;">
          <svg width="14" height="6" viewBox="0 0 14 6">
            <defs>
              <pattern id="lg-hatch" patternUnits="userSpaceOnUse" width="5" height="5" patternTransform="rotate(45)">
                <line x1="0" y1="0" x2="0" y2="5" stroke="var(--ink)" stroke-width="0.5" opacity="0.5" />
              </pattern>
            </defs>
            <rect x="0" y="0" width="14" height="6" fill="url(#lg-hatch)" />
          </svg>
          <span class="sc" style="font-size: 10.5px; letter-spacing: 0.08em; color: var(--ink-2);">Not applicable</span>
        </span>
      </span>
    </div>
  </div>
</Page>
