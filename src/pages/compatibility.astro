---
import { getCollection } from 'astro:content';
import { Code } from 'astro:components';
import Page from '../layouts/Page.astro';
import { getRootstockDump, findVerification, cellStateFor, type CellState } from '../lib/rootstock';
import { url } from '../lib/url';

// Paper-and-ink syntax theme for the How-To snippet. Ink for default text,
// oxblood for keywords and string literals, muted ink for comments/punctuation.
const almanacCodeTheme = {
  name: 'almanac',
  type: 'light' as const,
  bg: 'rgba(26,22,18,0.035)',
  fg: '#1f1c18',
  settings: [
    { settings: { foreground: '#1f1c18', background: 'rgba(26,22,18,0.035)' } },
    { scope: ['comment', 'comment.line', 'comment.block', 'punctuation.definition.comment'],
      settings: { foreground: '#7a7268', fontStyle: 'italic' } },
    { scope: ['keyword', 'keyword.control', 'keyword.operator.expression', 'storage.type', 'storage.modifier'],
      settings: { foreground: '#7a1f1f' } },
    { scope: ['string', 'string.quoted', 'string.quoted.single', 'string.quoted.double', 'punctuation.definition.string'],
      settings: { foreground: '#5a1414' } },
    { scope: ['constant.numeric', 'constant.language'],
      settings: { foreground: '#5a1414' } },
    { scope: ['entity.name.function', 'support.function', 'meta.function-call.generic'],
      settings: { foreground: '#1f1c18', fontStyle: 'bold' } },
    { scope: ['entity.name.class', 'support.class'],
      settings: { foreground: '#1f1c18', fontStyle: 'bold' } },
    { scope: ['variable.parameter.function-call', 'variable.parameter'],
      settings: { foreground: '#4a4540' } },
    { scope: ['punctuation', 'meta.brace', 'punctuation.separator'],
      settings: { foreground: '#4a4540' } },
  ],
};

const clusters = (await getCollection('clusters')).sort((a, b) => {
  const oa = a.data.order ?? 999;
  const ob = b.data.order ?? 999;
  if (oa !== ob) return oa - ob;
  return a.data.name.localeCompare(b.data.name);
});

const models = await getCollection('models');

// Flatten to one row per checkpoint, keeping a back-reference to the model
// page. Sort by family → params (descending, where known) → id.
const parseParams = (p: string | undefined): number => {
  if (!p) return -1;
  const n = parseFloat(p);
  if (Number.isNaN(n)) return -1;
  return n * (p.endsWith('B') ? 1000 : 1);
};
const rows = models
  .flatMap((m) =>
    m.data.checkpoints.map((cp) => ({
      pageId: m.id,
      pageName: m.data.name,
      family: m.data.family.id,
      checkpointId: cp.id,
      params: cp.params,
    })),
  )
  .sort((a, b) => {
    const fam = a.family.localeCompare(b.family);
    if (fam !== 0) return fam;
    const page = a.pageId.localeCompare(b.pageId);
    if (page !== 0) return page;
    const pa = parseParams(a.params);
    const pb = parseParams(b.params);
    if (pa !== pb) return pb - pa;
    return a.checkpointId.localeCompare(b.checkpointId);
  });

const dump = await getRootstockDump();

const cellSvg = (state: CellState): string => {
  if (state === 'verified') {
    return '<svg width="14" height="14" viewBox="0 0 14 14" aria-label="verified"><circle cx="7" cy="7" r="3.6" fill="var(--oxblood)" /></svg>';
  }
  if (state === 'lapsed') {
    return '<svg width="14" height="14" viewBox="0 0 14 14" aria-label="lapsed"><circle cx="7" cy="7" r="3.4" fill="none" stroke="var(--oxblood)" stroke-width="1" /></svg>';
  }
  return '<svg width="100%" height="14" viewBox="0 0 40 14" preserveAspectRatio="none" aria-label="not applicable" style="display: block;"><defs><pattern id="na-hatch" patternUnits="userSpaceOnUse" width="5" height="5" patternTransform="rotate(45)"><line x1="0" y1="0" x2="0" y2="5" stroke="var(--ink)" stroke-width="0.5" opacity="0.35" /></pattern></defs><rect x="0" y="3" width="40" height="8" fill="url(#na-hatch)" /></svg>';
};

let counts = { verified: 0, lapsed: 0, na: 0 };
const grid = rows.map((row) => ({
  row,
  cells: clusters.map((c) => {
    const state: CellState = cellStateFor(findVerification(dump, c.id, row.checkpointId));
    counts[state]++;
    return { cluster: c, state };
  }),
}));

const codeSnippet = `from ase.build import bulk
from rootstock import RootstockCalculator

atoms = bulk("Cu", "fcc", a=3.6) * (5, 5, 5)

with RootstockCalculator(
  cluster="perlmutter",
  checkpoint="mace-mp-0-medium",
  device="cuda",
) as calc:
    atoms.calc = calc
    print(atoms.get_potential_energy())`;
---
<Page
  title="The Compatibility Matrix — Garden's Almanac"
  section="The Compatibility Matrix"
  folioId="§ Pull-out"
  wide
>
  <style>
    .matrix-table { table-layout: fixed; }
    .matrix-table th.cluster-h { text-align: center; vertical-align: bottom; padding: 6px 4px; line-height: 1.2; }
    .matrix-table td.cell { text-align: center; padding: 4px 0; }
    .matrix-table td.checkpoint-id { font-family: var(--mono); font-size: 11px; color: var(--ink-2); }
    .howto pre {
      margin: 4px 0 0;
      font-family: var(--mono);
      font-size: 9.75px;
      line-height: 1.4;
      padding: 5px 8px;
      overflow-x: auto;
      white-space: pre;
      background: rgba(26, 22, 18, 0.035);
      border: 0.5px solid var(--rule);
    }
  </style>

  <div style="display: grid; grid-template-columns: 1fr 460px; gap: 28px; align-items: start;">
    <div>
      <p class="sc" style="font-size: 11.5px; letter-spacing: 0.14em; color: var(--ink-2);">Pull-out reference</p>
      <h1 style="font-size: 36px; margin-top: 2px; line-height: 1;">The Availability Matrix</h1>
      <p class="it" style="color: var(--ink-2); font-size: 12.75px; margin-top: 4px; max-width: 720px; line-height: 1.4;">
        A filled circle means Rootstock tested the install and ran a basic inference within the last
        seven days. An open circle means that check has lapsed. Hatched cells are not supported.
      </p>
    </div>

    <section class="howto" style="border-left: 0.5px solid var(--rule); padding-left: 18px;">
      <div class="sc" style="font-size: 11px; letter-spacing: 0.14em; color: var(--ink); margin-bottom: 3px;">
        How to use these models
      </div>
      <p style="margin: 0 0 4px; font-size: 11px; line-height: 1.4; color: var(--ink);">
        A filled circle means the checkpoint is ready to run with Rootstock
        on that cluster. Install the Rootstock Python library with pip or uv, and then use a
        {' '}<span class="mono" style="font-size: 10.5px;">RootstockCalculator</span>{' '}
        which plugs in wherever you use ASE calculators.
      </p>
      <Code code={codeSnippet} lang="python" theme={almanacCodeTheme} />
      <div style="display: grid; grid-template-columns: auto 1fr; column-gap: 8px; row-gap: 1px; font-size: 10px; line-height: 1.35; color: var(--ink); margin-top: 5px;">
        <div class="sc" style="font-size: 9.5px; letter-spacing: 0.10em; color: var(--ink-2); align-self: start;">Further →</div>
        <div>
          <a class="ink-link it" href="https://garden-ai.github.io/rootstock/">Rootstock docs</a>
          <span style="color: var(--ink-2);"> — More details, including LAMMPS compatibility.</span>
        </div>
        <div></div>
        <div>
          <a class="ink-link it" href="https://gitlab.osti.gov/genesis/genesis-skills/-/tree/main/skills/modcon-skills">DOE agent skills</a>
          <span style="color: var(--ink-2);"> — Skills to run on DOE clusters with agents (incl. Academy).</span>
        </div>
        <div></div>
      </div>
    </section>
  </div>
  <hr class="double-rule" style="margin-top: 8px; margin-bottom: 8px;" />

  <div class="cm-tight">
    <table class="almanac matrix-table">
      <colgroup>
        <col style="width: 24px;" />
        <col style="width: 160px;" />
        <col style="width: 180px;" />
        <col style="width: 60px;" />
        {clusters.map(() => <col />)}
        <col />
      </colgroup>
      <thead>
        <tr>
          <th>№</th>
          <th>Model</th>
          <th>Checkpoint</th>
          <th style="text-align: right;">Size</th>
          {clusters.map((c) => (
            <th class="cluster-h">
              <div style="font-family: var(--smallcaps); font-size: 12.5px; letter-spacing: 0.06em;">
                <a class="ink-link" href={url(`/cluster/${c.id}`)}>{c.data.name}</a>
              </div>
              <div class="sc" style="font-size: 9.5px; letter-spacing: 0.10em; color: var(--ink-2);">
                {c.data.institutionShort ?? c.data.institution.split('·')[0].trim()}
              </div>
              <div class="mono" style="font-size: 9px; color: var(--ink-3); letter-spacing: 0.02em;">
                {c.data.gpu ?? '—'}
              </div>
            </th>
          ))}
          <th class="cluster-h">
            <div style="font-family: var(--smallcaps); font-size: 12.5px; letter-spacing: 0.06em; font-style: italic; color: var(--ink-3);">
              + more
            </div>
            <div class="sc" style="font-size: 9.5px; letter-spacing: 0.10em; color: var(--ink-2);">
              Coming soon
            </div>
            <div class="mono" style="font-size: 9px; color: var(--ink-3); letter-spacing: 0.02em;">—</div>
          </th>
        </tr>
      </thead>
      <tbody>
        {grid.map(({ row, cells }, i) => (
          <tr>
            <td style="font-variant-numeric: tabular-nums; color: var(--ink-2);">{String(i + 1).padStart(2, '0')}</td>
            <td><a class="ink-link" href={url(`/model/${row.pageId}`)} style="font-weight: 600;">{row.pageName}</a></td>
            <td class="checkpoint-id">{row.checkpointId}</td>
            <td style="text-align: right; font-variant-numeric: tabular-nums;">{row.params ?? '—'}</td>
            {cells.map(({ cluster, state }) => (
              <td class="cell" data-rs-cell={`${cluster.id}:${row.checkpointId}`} set:html={cellSvg(state)} />
            ))}
            <td class="cell">
              <span style="color: var(--ink-3); opacity: 0.6; font-size: 12px;">·</span>
            </td>
          </tr>
        ))}
      </tbody>
    </table>

    <div style="display: flex; justify-content: space-between; align-items: baseline; margin-top: 8px; font-size: 11.5px;">
      <span class="it" style="color: var(--ink-2);">
        {rows.length} checkpoints · {clusters.length} clusters ·
        {' '}<span data-rs-count="verified">{counts.verified}</span> verified,
        {' '}<span data-rs-count="lapsed">{counts.lapsed}</span> lapsed,
        {' '}<span data-rs-count="na">{counts.na}</span> not applicable
      </span>
      <span style="display: inline-flex; align-items: center; gap: 14px;">
        <span style="display: inline-flex; align-items: center; gap: 6px;">
          <svg width="14" height="14" viewBox="0 0 14 14"><circle cx="7" cy="7" r="3.6" fill="var(--oxblood)" /></svg>
          <span class="sc" style="font-size: 10.5px; letter-spacing: 0.08em; color: var(--ink-2);">Verified</span>
        </span>
        <span style="display: inline-flex; align-items: center; gap: 6px;">
          <svg width="14" height="14" viewBox="0 0 14 14"><circle cx="7" cy="7" r="3.4" fill="none" stroke="var(--oxblood)" stroke-width="1" /></svg>
          <span class="sc" style="font-size: 10.5px; letter-spacing: 0.08em; color: var(--ink-2);">Lapsed</span>
        </span>
        <span style="display: inline-flex; align-items: center; gap: 6px;">
          <svg width="14" height="6" viewBox="0 0 14 6">
            <defs>
              <pattern id="lg-hatch" patternUnits="userSpaceOnUse" width="5" height="5" patternTransform="rotate(45)">
                <line x1="0" y1="0" x2="0" y2="5" stroke="var(--ink)" stroke-width="0.5" opacity="0.5" />
              </pattern>
            </defs>
            <rect x="0" y="0" width="14" height="6" fill="url(#lg-hatch)" />
          </svg>
          <span class="sc" style="font-size: 10.5px; letter-spacing: 0.08em; color: var(--ink-2);">Not applicable</span>
        </span>
      </span>
    </div>
  </div>
</Page>

<script>
  import { loadLiveDump } from '../lib/rootstock-client';
  import { findVerification, cellStateFor, type CellState } from '../lib/rootstock';

  const cellSvg = (state: CellState): string => {
    if (state === 'verified') {
      return '<svg width="14" height="14" viewBox="0 0 14 14" aria-label="verified"><circle cx="7" cy="7" r="3.6" fill="var(--oxblood)" /></svg>';
    }
    if (state === 'lapsed') {
      return '<svg width="14" height="14" viewBox="0 0 14 14" aria-label="lapsed"><circle cx="7" cy="7" r="3.4" fill="none" stroke="var(--oxblood)" stroke-width="1" /></svg>';
    }
    return '<svg width="100%" height="14" viewBox="0 0 40 14" preserveAspectRatio="none" aria-label="not applicable" style="display: block;"><defs><pattern id="na-hatch" patternUnits="userSpaceOnUse" width="5" height="5" patternTransform="rotate(45)"><line x1="0" y1="0" x2="0" y2="5" stroke="var(--ink)" stroke-width="0.5" opacity="0.35" /></pattern></defs><rect x="0" y="3" width="40" height="8" fill="url(#na-hatch)" /></svg>';
  };

  loadLiveDump()
    .then((dump) => {
      const counts = { verified: 0, lapsed: 0, na: 0 };
      document.querySelectorAll<HTMLElement>('[data-rs-cell]').forEach((td) => {
        const [cluster, checkpoint] = td.dataset.rsCell!.split(':');
        const state = cellStateFor(findVerification(dump, cluster, checkpoint));
        td.innerHTML = cellSvg(state);
        counts[state]++;
      });
      document.querySelectorAll<HTMLElement>('[data-rs-count]').forEach((el) => {
        const k = el.dataset.rsCount as keyof typeof counts;
        el.textContent = String(counts[k]);
      });
    })
    .catch((err) => console.warn('Rootstock live refresh failed', err));
</script>
