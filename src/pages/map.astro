---
import { getCollection } from 'astro:content';
import Page from '../layouts/Page.astro';
import OrnamentRule from '../components/OrnamentRule.astro';
import MapStage from '../components/MapStage.astro';

// Display order — OMol25 first because its CKNNA matrix is the densest
// (pairwise coverage across all the materials/molecular MLIPs in the study).
const DISPLAY_ORDER = ['map-omol25', 'map-omat24', 'map-qm9', 'map-salex'];

const all = await getCollection('embeddings');
const layouts = DISPLAY_ORDER
  .map((id) => all.find((e) => e.id === id))
  .filter((e): e is NonNullable<typeof e> => Boolean(e));

if (layouts.length === 0) {
  throw new Error('no embeddings/* layouts found — run almanac_embeddings/export_layouts.py');
}

const tabs = layouts.map((l, i) => ({
  id: l.id,
  inputId: `ds-${l.id}`,
  label: l.data.dataset,
  layout: l,
  isFirst: i === 0,
}));
---

<Page title="The Map — Garden's Almanac" section="The Map" folioId="§02">
  <header class="map-head">
    <p class="sc map-eyebrow">Section 02</p>
    <h1 class="map-title">The Map</h1>
    <p class="it map-subtitle">
      Foundation models for matter, charted by representational similarity.
    </p>
  </header>
  <div class="map-rule"><OrnamentRule width={220} /></div>

  <div class="map-bar">
    <p class="it map-inscription">
      Proximity encodes representational similarity (CKNNA, <span class="map-mono">k = 25</span>).
      The axes themselves carry no independent meaning.
    </p>
    <fieldset class="map-toggle">
      <legend class="sc map-toggle-legend">Reference dataset</legend>
      <div class="map-toggle-tabs">
        {tabs.map((t) => (
          <>
            <input
              class="map-toggle-input"
              type="radio"
              name="ds"
              id={t.inputId}
              value={t.id}
              data-ds={t.label}
              checked={t.isFirst}
            />
            <label for={t.inputId} class="sc map-toggle-tab">{t.label}</label>
          </>
        ))}
      </div>
    </fieldset>
  </div>

  <div class="map-stages">
    {tabs.map((t) => (
      <MapStage layout={t.layout} active={t.isFirst} />
    ))}
  </div>
</Page>

<style>
  .map-head {
    margin: 0;
  }
  .map-eyebrow {
    font-size: 12px;
    letter-spacing: 0.18em;
    color: var(--ink-2);
    margin: 0;
  }
  .map-title {
    margin: 3px 0 0;
  }
  .map-subtitle {
    color: var(--ink-2);
    margin: 4px 0 0;
    font-size: 14.5px;
  }
  .map-rule {
    margin: 10px 0 16px;
  }

  /* Inscription + toggle share a row; inscription left, tabs right.
     On narrow viewports they stack; the toggle stays right-aligned. */
  .map-bar {
    display: flex;
    align-items: flex-end;
    justify-content: space-between;
    gap: 24px;
    margin-bottom: 10px;
    flex-wrap: wrap;
  }
  .map-inscription {
    margin: 0;
    color: var(--ink-2);
    font-size: 13px;
    line-height: 1.45;
    max-width: 52ch;
    flex: 1 1 320px;
  }
  .map-mono {
    font-family: var(--mono);
    font-style: normal;
    font-size: 12px;
  }

  /* Tab strip — almanac-style: small caps, hairline underline on active. */
  .map-toggle {
    border: none;
    margin: 0;
    padding: 0;
    flex: 0 0 auto;
    margin-left: auto; /* right-align even when wrapped */
  }
  .map-toggle-legend {
    display: block;
    font-size: 10.5px;
    letter-spacing: 0.10em;
    color: var(--ink-2);
    margin: 0 0 6px;
    padding: 0;
    text-align: right;
  }
  .map-toggle-tabs {
    display: flex;
    align-items: baseline;
    gap: 0;
    border-top: 0.5px solid var(--ink);
    border-bottom: 0.5px solid var(--ink);
    padding: 4px 0 3px;
  }
  .map-toggle-input {
    /* Hidden but focusable; the label is the visible control. */
    position: absolute;
    opacity: 0;
    pointer-events: none;
    width: 0;
    height: 0;
  }
  .map-toggle-tab {
    display: inline-block;
    font-size: 12px;
    letter-spacing: 0.14em;
    color: var(--ink-2);
    padding: 4px 12px 4px;
    cursor: pointer;
    user-select: none;
    border-left: 0.5px solid var(--ink-2);
    transition: color 0.12s;
  }
  .map-toggle-tab:first-of-type {
    border-left: none;
  }
  .map-toggle-tab:hover {
    color: var(--ink);
  }
  .map-toggle-input:checked + .map-toggle-tab {
    color: var(--paper);
    background: var(--ink);
  }
  .map-toggle-input:focus-visible + .map-toggle-tab {
    outline: 1px dotted var(--ink);
    outline-offset: 2px;
  }
</style>

<script>
  // CSS-only tabs would need sibling selectors spanning header → body, which
  // our structure doesn't allow. A handful of JS keeps the markup semantic.
  const inputs = document.querySelectorAll<HTMLInputElement>('.map-toggle-input');
  const stages = document.querySelectorAll<HTMLElement>('.map-stage');
  const show = (ds: string | undefined) => {
    if (!ds) return;
    stages.forEach((s) => s.classList.toggle('is-active', s.dataset.ds === ds));
  };
  inputs.forEach((input) =>
    input.addEventListener('change', () => {
      if (input.checked) show(input.dataset.ds);
    }),
  );
</script>
