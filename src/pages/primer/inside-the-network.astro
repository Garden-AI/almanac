        <text x="373" y="110" text-anchor="middle" class="svg-small">sum &amp; update</text>

        <text x="470" y="86" class="svg-serif-it">new scratchpad of i =</text>
        <text x="470" y="116" class="svg-small">update( old scratchpad,</text>
        <text x="492" y="136" class="svg-small">msg₁ + msg₂ + msg₃ )</text>
        <text x="470" y="170" class="svg-small">each msg = shape( neighbor's</text>
        <text x="492" y="190" class="svg-small">scratchpad, the edge to it )</text>

