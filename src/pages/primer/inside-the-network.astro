        <text x="516" y="120" text-anchor="middle" class="svg-small">equivariant, many rounds</text>

        <text x="252" y="184" text-anchor="middle" class="svg-serif-it">Behler–Parrinello · ACE</text>
        <text x="252" y="204" text-anchor="middle" class="svg-small">hand-built, one layer</text>

        <text x="516" y="184" text-anchor="middle" class="svg-serif-it" style="fill:var(--oxblood);">MACE</text>
        <text x="516" y="204" text-anchor="middle" class="svg-small">equivariant, high body order</text>

        <defs>
