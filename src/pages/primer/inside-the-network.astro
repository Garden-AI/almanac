        <line x1="430" y1="120" x2="498" y2="120" stroke="var(--ink)" stroke-width="1.2" marker-end="url(#ch3aA)" />

        <text x="520" y="116" text-anchor="middle" class="svg-serif" style="font-size:17px;">εᵢ</text>
        <text x="520" y="138" text-anchor="middle" class="svg-small">atom i's energy</text>

        <line x1="40" y1="170" x2="680" y2="170" stroke="var(--rule)" stroke-width="0.5" stroke-dasharray="2 4" />
        <text x="360" y="198" text-anchor="middle" class="svg-serif-it">E = ε₁ + ε₂ + ε₃ + ⋯ + εₙ</text>
