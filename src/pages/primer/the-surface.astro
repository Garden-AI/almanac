        <circle cx="120" cy="92" r="22" fill="none" stroke="var(--ink)" stroke-width="1.2" />
        <line x1="120" y1="92" x2="120" y2="76" stroke="var(--ink)" stroke-width="1.2" />
        <line x1="120" y1="92" x2="133" y2="99" stroke="var(--ink)" stroke-width="1.2" />
