        <text x="118" y="135" text-anchor="middle" class="svg-small">measured</text>
        <text x="118" y="148" text-anchor="middle" class="svg-small">results → data</text>

        <defs>
          <marker id="ch7arrB" markerWidth="9" markerHeight="9" refX="7" refY="4.5" orient="auto"><path d="M0 0 L9 4.5 L0 9 z" fill="var(--ink)" /></marker>
          <marker id="ch7arrC" markerWidth="9" markerHeight="9" refX="7" refY="4.5" orient="auto"><path d="M0 0 L9 4.5 L0 9 z" fill="var(--oxblood)" /></marker>
