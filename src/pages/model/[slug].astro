---
import { getCollection, getEntry } from 'astro:content';
import { marked } from 'marked';
import Page from '../../layouts/Page.astro';
import MapStage from '../../components/MapStage.astro';
import { getRootstockDump, findVerification, cellStateFor, type CellState } from '../../lib/rootstock';
import { url } from '../../lib/url';
import { formatBytes, formatMonthYear, yearOf } from '../../lib/format';

export async function getStaticPaths() {
  const models = await getCollection('models');
  return models.map((m) => ({ params: { slug: m.id }, props: { model: m } }));
}

const { model } = Astro.props;

const families = await Promise.all(
  model.data.families.map((ref) => getEntry('architectures', ref.id)),
);
const trainingDatasets = await Promise.all(
  model.data.trainingData.map((ref) => getEntry('datasets', ref.id)),
);
const papers = await Promise.all(
  model.data.paperRefs.map((ref) => getEntry('papers', ref.id)),
);

// Completeness check: any paper referenced by a model must have at minimum
// title, authors, published, url. Stubs (just doi+source) fail loudly so
// shipping a model that points at an unfilled stub isn't possible.
for (const p of papers) {
  if (!p) continue;
  const d = p.data;
  const incomplete = !d.title || !d.authors?.length || !d.published || !d.url;
  if (incomplete && d.source === 'fetched') {
    throw new Error(
      `Paper '${p.id}' is a stub. Run npm run fetch:papers.`,
    );
  }
}

// Resolved release date: explicit override, else first paper's `published`.
const primaryPaper = papers.find((p) => p?.data.published) ?? null;
const resolvedDate = model.data.releaseDate ?? primaryPaper?.data.published ?? null;
const dateLine = formatMonthYear(resolvedDate);

const allClusters = (await getCollection('clusters')).sort((a, b) => {
  const oa = a.data.order ?? 999;
  const ob = b.data.order ?? 999;
  if (oa !== ob) return oa - ob;
  return a.data.name.localeCompare(b.data.name);
});

const dump = await getRootstockDump();

// Render a column for *every* cluster. Columns where the current dump shows
// no presence get an `am-hidden` class server-side; the live-refresh script
// re-derives that per column, so a stale build can't strand a real cluster.
const matrix = model.data.checkpoints.map((cp) => ({
  checkpoint: cp,
  cells: allClusters.map((c) => {
    const v = findVerification(dump, c.id, cp.id);
    return {
      cluster: c,
      state: cellStateFor(v) as CellState,
      verifiedAt: v?.verifiedAt ?? null,
      lastError: v?.lastError ?? null,
    };
  }),
}));

const clusterHasPresence: Record<string, boolean> = {};
for (const c of allClusters) {
  clusterHasPresence[c.id] = model.data.checkpoints.some(
    (cp) => findVerification(dump, c.id, cp.id) !== null,
  );
}
const anyPresence = Object.values(clusterHasPresence).some(Boolean);

const glyphHtml = (state: CellState): string => {
  if (state === 'verified') {
    return '<span class="status-verified" title="Verified within the last 30 days" aria-label="verified">●</span>';
  }
  if (state === 'lapsed') {
    return '<span class="status-stale" title="Installed but not recently verified" aria-label="installed, not recently verified">○</span>';
  }
  return '<span class="status-na" title="Not installed on this cluster" aria-label="not installed">—</span>';
};

const weightsDomainLabel = (u: string): string => {
  try {
    const h = new URL(u).hostname.replace(/^www\./, '');
    if (h.includes('zenodo.org')) return 'Zenodo';
    if (h.includes('github.com')) return 'GitHub Release';
    if (h.includes('figshare.com')) return 'Figshare';
    if (h.includes('huggingface.co')) return 'Hugging Face';
    return h;
  } catch {
    return 'Weights';
  }
};

const codeDomainLabel = (u: string): string => {
  try {
    const h = new URL(u).hostname.replace(/^www\./, '');
    if (h.includes('github.com')) return 'GitHub';
    if (h.includes('gitlab.com')) return 'GitLab';
    return h;
  } catch {
    return 'Code';
  }
};

const paperDomainLabel = (u: string): string => {
  try {
    const h = new URL(u).hostname.replace(/^www\./, '');
    if (h.includes('arxiv.org')) return 'arXiv';
    if (h.includes('doi.org')) return 'DOI';
    return h;
  } catch {
    return 'Paper';
  }
};

const paperLink = (() => {
  // Masthead Paper link: prefer the first paper's URL/DOI, else nothing.
  const p = papers.find((p) => p?.data.url || p?.data.doi);
  if (!p) return null;
  const href = p.data.doi ? `https://doi.org/${p.data.doi}` : p.data.url!;
  return { href, label: paperDomainLabel(href) };
})();

const composeCitation = (data: { authors?: string[]; title?: string; venue?: string; published?: string; citation?: string }): string => {
  if (data.citation) return data.citation;
  const parts: string[] = [];
  if (data.authors?.length) parts.push(data.authors.join(', '));
  if (data.title) parts.push(data.title);
  if (data.venue) parts.push(data.venue);
  const y = yearOf(data.published);
  if (y) parts.push(String(y));
  return parts.join(', ') + (parts.length ? '.' : '');
};

const notesHtml = model.data.notes ? marked.parse(model.data.notes) : null;

// Similarity-map setup. Each map layout's id follows `map-<dataset-id>`,
// so the model's first training dataset picks its primary reference layout.
const MAP_DISPLAY_ORDER = ['map-omol25', 'map-omat24', 'map-qm9', 'map-salex'];
const allLayouts = await getCollection('embeddings');
const orderedLayouts = MAP_DISPLAY_ORDER
  .map((id) => allLayouts.find((e) => e.id === id))
  .filter((e): e is NonNullable<typeof e> => Boolean(e));

const primaryDatasetId = model.data.trainingData[0]?.id;
const primaryLayoutId = primaryDatasetId ? `map-${primaryDatasetId}` : null;
// Only consider layouts that actually contain this model as the "default."
const layoutsWithModel = orderedLayouts.filter((l) =>
  l.data.points.some((p) => p.slug?.id === model.id),
);
const defaultLayoutId =
  (primaryLayoutId && layoutsWithModel.find((l) => l.id === primaryLayoutId)?.id) ??
  layoutsWithModel[0]?.id ??
  orderedLayouts[0]?.id ??
  null;

const mapTabs = orderedLayouts.map((l) => ({
  id: l.id,
  inputId: `model-ds-${l.id}`,
  label: l.data.dataset,
  layout: l,
  isDefault: l.id === defaultLayoutId,
}));
const showMap = orderedLayouts.length > 0 && defaultLayoutId !== null;
---
<Page title={`${model.data.name} — Garden's Almanac`}>
  <div class="model-masthead">
    <h1>{model.data.name}</h1>
    {dateLine && (
      <p class="it" style="font-size: 14px; color: var(--ink-2); margin-top: 6px;">
        {dateLine}
      </p>
    )}

    {(paperLink || model.data.codeUrl || model.data.huggingFaceId || model.data.weightsUrl) && (
      <div class="masthead-links">
        {paperLink && (
          <div class="masthead-link">
            <span class="sc">Paper</span>
            <a class="ink-link" href={paperLink.href} target="_blank" rel="noopener">
              {paperLink.label} <span style="color: var(--ink-3);">↗</span>
            </a>
          </div>
        )}
        {model.data.codeUrl && (
          <div class="masthead-link">
            <span class="sc">Code</span>
            <a class="ink-link" href={model.data.codeUrl} target="_blank" rel="noopener">
              {codeDomainLabel(model.data.codeUrl)} <span style="color: var(--ink-3);">↗</span>
            </a>
          </div>
        )}
        {model.data.huggingFaceId ? (
          <div class="masthead-link">
            <span class="sc">Weights</span>
            <span style="display: inline-flex; align-items: baseline; gap: 6px;">
              <span aria-hidden="true">🤗</span>
              <a class="ink-link mono" style="font-size: 12.5px;"
                 href={`https://huggingface.co/${model.data.huggingFaceId}`}
                 target="_blank" rel="noopener">{model.data.huggingFaceId}</a>
            </span>
          </div>
        ) : model.data.weightsUrl ? (
          <div class="masthead-link">
            <span class="sc">Weights</span>
            <a class="ink-link" href={model.data.weightsUrl} target="_blank" rel="noopener">
              {weightsDomainLabel(model.data.weightsUrl)} <span style="color: var(--ink-3);">↗</span>
            </a>
          </div>
        ) : null}
      </div>
    )}
  </div>

  <div style="height: 18px;"></div>

  <section class="checkpoint-matrix">
    <div style="overflow-x: auto;">
      <table class="almanac" style="font-size: 13px;">
        <thead>
          <tr>
            <th>Checkpoint</th>
            <th style="width: 80px; text-align: right;">Params</th>
            <th style="width: 80px; text-align: right;">Size</th>
            {allClusters.map((c) => (
              <th
                class:list={["am-mx-col", !clusterHasPresence[c.id] && "am-hidden"]}
                data-rs-col={c.id}
                style="width: 84px; text-align: center;"
              >
                <a class="ink-link" href={url(`/cluster/${c.id}`)} style="border-bottom-color: transparent;">
                  {c.data.name}
                </a>
              </th>
            ))}
          </tr>
        </thead>
        <tbody>
          {matrix.map(({ checkpoint, cells }) => (
            <tr>
              <td class="mono" style="font-size: 12.25px;">{checkpoint.id}</td>
              <td style="text-align: right; font-variant-numeric: tabular-nums;">
                {checkpoint.params ?? ''}
              </td>
              <td style="text-align: right; font-variant-numeric: tabular-nums; color: var(--ink-2);">
                {formatBytes(checkpoint.weightsBytes)}
              </td>
              {cells.map((cell) => (
                <td
                  class:list={["am-mx-col", !clusterHasPresence[cell.cluster.id] && "am-hidden"]}
                  style="text-align: center;"
                  data-rs-col={cell.cluster.id}
                  data-rs-cell={`${cell.cluster.id}:${checkpoint.id}`}
                  set:html={glyphHtml(cell.state)}
                />
              ))}
            </tr>
          ))}
        </tbody>
      </table>
    </div>

    <div class:list={["matrix-legend", !anyPresence && "am-hidden"]} data-rs-legend>
      <span><span class="status-verified">●</span> <span class="it">verified, last 30 days</span></span>
      <span><span class="status-stale">○</span> <span class="it">installed, not recently verified</span></span>
      <span><span class="status-na">—</span> <span class="it">not installed</span></span>
    </div>
    <p
      class:list={["it", anyPresence && "am-hidden"]}
      data-rs-empty
      style="font-size: 12px; color: var(--ink-2); margin-top: 8px;"
    >
      No cluster has installed any checkpoint of this model yet.
    </p>
  </section>

  <hr class="hairline" style="margin: 18px 0 10px;" />

  <div class="model-body">
    <section>
      <header>
        <div class="sc" style="font-size: 11.5px; letter-spacing: 0.10em;">References</div>
      </header>
      {papers.length > 0 ? (
        <ol style="margin: 8px 0 0; padding-left: 24px; font-size: 13px; line-height: 1.5; color: var(--ink-2);">
          {papers.map((p) => {
            if (!p) return null;
            const cite = composeCitation(p.data);
            const href = p.data.doi ? `https://doi.org/${p.data.doi}` : p.data.url;
            return (
              <li style="margin-bottom: 6px; padding-left: 4px;">
                {href ? (
                  <a class="ink-link" href={href} target="_blank" rel="noopener">{cite}</a>
                ) : (
                  cite
                )}
              </li>
            );
          })}
        </ol>
      ) : (
        <p class="it" style="font-size: 12.5px; color: var(--ink-3); margin-top: 8px;">
          — no references catalogued yet —
        </p>
      )}
    </section>

    <aside class="spec-rail">
      <header>
        <div class="sc" style="font-size: 11.5px; letter-spacing: 0.10em;">Specifications</div>
      </header>
      <dl class="spec-list">
        {families.length > 0 && (
          <>
            <dt class="sc">{families.length > 1 ? 'Families' : 'Family'}</dt>
            <dd>
              {families.map((f, i) => f && (
                <>
                  {i > 0 && <span style="color: var(--ink-3);">, </span>}
                  <a class="ink-link it" href={url(`/architecture/${f.id}`)}>{f.data.name}</a>
                </>
              ))}
            </dd>
          </>
        )}
        {trainingDatasets.length > 0 && (
          <>
            <dt class="sc">Trained on</dt>
            <dd>
              {trainingDatasets.map((d, i) => d && (
                <>
                  {i > 0 && <span style="color: var(--ink-3);">, </span>}
                  <a class="ink-link" href={url(`/dataset/${d.id}`)}>{d.data.name}</a>
                </>
              ))}
            </dd>
          </>
        )}
        {model.data.cachePath && (
          <>
            <dt class="sc">Cache path</dt>
            <dd><code class="mono" style="font-size: 12px; color: var(--ink-2); word-break: break-all;">{model.data.cachePath}</code></dd>
          </>
        )}
      </dl>
    </aside>
  </div>

  {notesHtml && (
    <section class="model-notes">
      <hr class="hairline" style="margin: 18px 0 10px;" />
      <div class="sc" style="font-size: 11.5px; letter-spacing: 0.10em;">Notes</div>
      <div class="notes-body" set:html={notesHtml} />
    </section>
  )}

  {showMap && (
    <section class="model-map">
      <hr class="hairline" style="margin: 24px 0 12px;" />
      <header class="model-map-head">
        <div>
          <div class="sc" style="font-size: 11.5px; letter-spacing: 0.10em;">Position on the similarity map</div>
          <p class="it" style="margin: 4px 0 0; font-size: 13px; color: var(--ink-2); max-width: 56ch;">
            {model.data.name} is highlighted. Neighbors are nearest-by-CKNNA on the selected reference dataset.
            Click any italic label to jump to that model.
          </p>
        </div>
        <fieldset class="map-toggle">
          <legend class="sc map-toggle-legend">Reference dataset</legend>
          <div class="map-toggle-tabs">
            {mapTabs.map((t) => (
              <>
                <input
                  class="map-toggle-input"
                  type="radio"
                  name="model-ds"
                  id={t.inputId}
                  value={t.id}
                  data-ds={t.label}
                  checked={t.isDefault}
                />
                <label for={t.inputId} class="sc map-toggle-tab">{t.label}</label>
              </>
            ))}
          </div>
        </fieldset>
      </header>
      <div class="map-stages">
        {mapTabs.map((t) => (
          <MapStage layout={t.layout} active={t.isDefault} highlightSlug={model.id} />
        ))}
      </div>
    </section>
  )}
</Page>

<style>
  .model-masthead h1 {
    font-size: 46px;
    line-height: 1.0;
    font-weight: 600;
    letter-spacing: -0.005em;
    margin-top: 2px;
  }

  .masthead-links {
    margin-top: 16px;
    display: flex;
    flex-wrap: wrap;
    gap: 10px 28px;
  }
  .masthead-link {
    display: flex;
    flex-direction: column;
    gap: 3px;
  }
  .masthead-link .sc {
    font-family: var(--smallcaps);
    font-size: 10.5px;
    letter-spacing: 0.12em;
    color: var(--ink-3);
  }

  .checkpoint-matrix .matrix-legend {
    margin-top: 8px;
    font-size: 12px;
    color: var(--ink-2);
    display: flex;
    gap: 14px;
    flex-wrap: wrap;
  }

  /* Server-render + live-refresh both toggle this class to drop cluster
     columns / status messages that don't apply per current Rootstock data. */
  .am-hidden { display: none; }

  .model-body {
    display: grid;
    grid-template-columns: 1fr 240px;
    column-gap: 32px;
    align-items: start;
  }
  .spec-rail {
    border-left: 0.5px solid var(--rule);
    padding-left: 18px;
  }
  .spec-list {
    display: grid;
    grid-template-columns: auto 1fr;
    row-gap: 5px;
    column-gap: 10px;
    margin: 10px 0 0;
    font-size: 13px;
  }
  .spec-list dt {
    font-family: var(--smallcaps);
    font-size: 11px;
    letter-spacing: 0.10em;
    color: var(--ink-3);
    padding-top: 1px;
    margin: 0;
  }
  .spec-list dd { margin: 0; }

  .notes-body {
    margin-top: 8px;
    font-size: 13.5px;
    line-height: 1.55;
    color: var(--ink);
    max-width: 720px;
  }
  .notes-body p { margin: 0 0 10px; }
  .notes-body ul { margin: 0 0 10px; padding-left: 18px; }
  .notes-body li { margin-bottom: 3px; }
  .notes-body code {
    font-family: var(--mono);
    background: rgba(26,22,18,0.05);
    padding: 0 4px;
  }
  .notes-body a { color: var(--oxblood); text-decoration: underline; text-decoration-thickness: 0.5px; text-underline-offset: 2px; }

  @media (max-width: 720px) {
    .model-body { grid-template-columns: 1fr; }
    .spec-rail { border-left: 0; padding-left: 0; margin-top: 18px; }
  }

  /* Embedded similarity map */
  .model-map { margin-top: 18px; }
  .model-map-head {
    display: flex;
    align-items: flex-end;
    justify-content: space-between;
    gap: 24px;
    flex-wrap: wrap;
    margin-bottom: 12px;
  }
  .map-toggle { border: none; margin: 0; padding: 0; flex: 0 0 auto; margin-left: auto; }
  .map-toggle-legend {
    display: block;
    font-size: 10.5px;
    letter-spacing: 0.10em;
    color: var(--ink-2);
    margin: 0 0 6px;
    padding: 0;
    text-align: right;
  }
  .map-toggle-tabs {
    display: flex;
    align-items: baseline;
    border-top: 0.5px solid var(--ink);
    border-bottom: 0.5px solid var(--ink);
    padding: 4px 0 3px;
  }
  .map-toggle-input { position: absolute; opacity: 0; pointer-events: none; width: 0; height: 0; }
  .map-toggle-tab {
    display: inline-block;
    font-size: 12px;
    letter-spacing: 0.14em;
    color: var(--ink-2);
    padding: 4px 12px;
    cursor: pointer;
    user-select: none;
    border-left: 0.5px solid var(--ink-2);
    transition: color 0.12s;
  }
  .map-toggle-tab:first-of-type { border-left: none; }
  .map-toggle-tab:hover { color: var(--ink); }
  .map-toggle-input:checked + .map-toggle-tab { color: var(--paper); background: var(--ink); }
</style>

<script>
  import { loadLiveDump } from '../../lib/rootstock-client';
  import { findVerification, cellStateFor, type CellState } from '../../lib/rootstock';

  const glyphHtml = (state: CellState): string => {
    if (state === 'verified') {
      return '<span class="status-verified" title="Verified within the last 30 days" aria-label="verified">●</span>';
    }
    if (state === 'lapsed') {
      return '<span class="status-stale" title="Installed but not recently verified" aria-label="installed, not recently verified">○</span>';
    }
    return '<span class="status-na" title="Not installed on this cluster" aria-label="not installed">—</span>';
  };

  loadLiveDump()
    .then((dump) => {
      const clusterHasPresence: Record<string, boolean> = {};
      document.querySelectorAll<HTMLElement>('[data-rs-cell]').forEach((td) => {
        const [cluster, checkpoint] = td.dataset.rsCell!.split(':');
        const state = cellStateFor(findVerification(dump, cluster, checkpoint));
        td.innerHTML = glyphHtml(state);
        if (state !== 'na') clusterHasPresence[cluster] = true;
      });
      // Toggle column visibility based on live presence (re-derived per page
      // load so a stale build doesn't drop a cluster that's since come up).
      document.querySelectorAll<HTMLElement>('[data-rs-col]').forEach((el) => {
        const cluster = el.dataset.rsCol!;
        el.classList.toggle('am-hidden', !clusterHasPresence[cluster]);
      });
      const anyPresence = Object.values(clusterHasPresence).some(Boolean);
      document.querySelectorAll<HTMLElement>('[data-rs-legend]').forEach((el) => {
        el.classList.toggle('am-hidden', !anyPresence);
      });
      document.querySelectorAll<HTMLElement>('[data-rs-empty]').forEach((el) => {
        el.classList.toggle('am-hidden', anyPresence);
      });
    })
    .catch((err) => console.warn('Rootstock live refresh failed', err));

  // Reference-dataset toggle for the embedded similarity map.
  const dsInputs = document.querySelectorAll<HTMLInputElement>('.map-toggle-input[name="model-ds"]');
  const stages = document.querySelectorAll<HTMLElement>('.model-map .map-stage');
  const showStage = (ds: string | undefined) => {
    if (!ds) return;
    stages.forEach((s) => s.classList.toggle('is-active', s.dataset.ds === ds));
  };
  dsInputs.forEach((input) =>
    input.addEventListener('change', () => {
      if (input.checked) showStage(input.dataset.ds);
    }),
  );
</script>
