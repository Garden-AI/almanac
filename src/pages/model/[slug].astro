---
import { getCollection, getEntry } from 'astro:content';
import Page from '../../layouts/Page.astro';
import { getRootstockDump, findVerification, cellStateFor, type CellState } from '../../lib/rootstock';
import { url } from '../../lib/url';

export async function getStaticPaths() {
  const models = await getCollection('models');
  return models.map((m) => ({ params: { slug: m.id }, props: { model: m } }));
}

const { model } = Astro.props;
const family = await getEntry('architectures', model.data.family.id);

const trainingData = await Promise.all(
  model.data.trainingData.map(async (t) => ({
    role: t.role,
    dataset: await getEntry('datasets', t.dataset.id),
  })),
);

// Per-checkpoint, per-cluster availability. Sophia has no manifest in
// the current dump — `getCheckpointVerification` returns null, and we
// render that as "n/a".
const clusters = (await getCollection('clusters')).sort((a, b) => {
  const oa = a.data.order ?? 999;
  const ob = b.data.order ?? 999;
  if (oa !== ob) return oa - ob;
  return a.data.name.localeCompare(b.data.name);
});

const dump = await getRootstockDump();

const checkpointAvailability = model.data.checkpoints.map((cp) => ({
  checkpoint: cp,
  perCluster: clusters.map((c) => {
    const v = findVerification(dump, c.id, cp.id);
    return {
      cluster: c,
      state: cellStateFor(v),
      verifiedAt: v?.verifiedAt,
      lastError: v?.lastError ?? null,
    };
  }),
}));

const statusHtml = (state: CellState, lastError: string | null): string => {
  if (state === 'verified') return '<span class="status-verified">●</span> verified';
  if (state === 'lapsed') return `<span class="status-stale">○</span> ${lastError ? 'errored' : 'lapsed'}`;
  return '<span style="color: var(--ink-3);">n/a</span>';
};
---
<Page
  title={`${model.data.name} — Garden's Almanac`}
  section="§ Model"
  folioId={`/model/${model.id}`}
>
  <p class="sc" style="font-size: 11.5px; letter-spacing: 0.14em;">
    {family?.data.name ?? 'Unknown family'}
  </p>
  <h1>{model.data.name}</h1>
  {(model.data.year || model.data.leadAuthor) && (
    <p class="it" style="color: var(--ink-2); font-size: 14px;">
      {model.data.year}{model.data.year && model.data.leadAuthor && ' · '}{model.data.leadAuthor}
    </p>
  )}
  <hr class="title-rule" />

  <div class="detail-body">
    <div>
      <h2 class="sc" style="font-size: 13px;">Specifications</h2>
      <table class="almanac" style="margin-top: 6px;">
        <tbody>
          <tr><td>Family</td><td><a class="ink-link it" href={url(`/architecture/${model.data.family.id}`)}>{family?.data.name}</a></td></tr>
          {model.data.year && <tr><td>Year</td><td>{model.data.year}</td></tr>}
          <tr>
            <td>Checkpoints</td>
            <td>
              {model.data.checkpoints.map((cp, i) => (
                <>
                  {i > 0 && ', '}
                  <span class="mono" style="font-size: 11.5px;">{cp.id}</span>
                  {cp.params && <span class="it" style="color: var(--ink-2);"> · {cp.params}</span>}
                </>
              ))}
            </td>
          </tr>
        </tbody>
      </table>

      {trainingData.length > 0 && (
        <>
          <h2 class="sc" style="font-size: 13px; margin-top: 22px;">Training data</h2>
          <table class="almanac" style="margin-top: 6px;">
            <thead><tr><th>Dataset</th><th>Used as</th></tr></thead>
            <tbody>
              {trainingData.map(({ dataset, role }) => (
                <tr>
                  <td><a class="ink-link it" href={url(`/dataset/${dataset?.id}`)}>{dataset?.data.name}</a></td>
                  <td class="it">{role}</td>
                </tr>
              ))}
            </tbody>
          </table>
        </>
      )}

      <h2 class="sc" style="font-size: 13px; margin-top: 22px;">Availability</h2>
      <p class="it" style="font-size: 12px; color: var(--ink-2); margin-top: 4px;">
        Per-checkpoint verification, by cluster. Verified within seven days = ●; older or errored = ○; absent = n/a.
      </p>
      {checkpointAvailability.map(({ checkpoint, perCluster }) => (
        <div style="margin-top: 14px;">
          <div class="mono" style="font-size: 11.5px;">
            {checkpoint.id}
            {checkpoint.params && (
              <span class="it" style="color: var(--ink-2); margin-left: 6px;">· {checkpoint.params}</span>
            )}
          </div>
          <table class="almanac" style="margin-top: 4px;">
            <thead><tr><th>Cluster</th><th style="width: 80px;">Status</th><th style="width: 110px;">Verified</th></tr></thead>
            <tbody>
              {perCluster.map(({ cluster, state, verifiedAt, lastError }) => (
                <tr data-rs-row={`${cluster.id}:${checkpoint.id}`}>
                  <td><a class="ink-link it" href={url(`/cluster/${cluster.id}`)}>{cluster.data.name}</a></td>
                  <td data-rs-status set:html={statusHtml(state, lastError)} />
                  <td class="mono" data-rs-verified style="font-variant-numeric: tabular-nums;">
                    {verifiedAt ? verifiedAt.slice(0, 10) : '—'}
                  </td>
                </tr>
              ))}
            </tbody>
          </table>
        </div>
      ))}
    </div>

    <aside class="detail-rail">
      {model.data.notes && (
        <div class="margin">
          <span class="label">Notes</span>
          <p class="it">{model.data.notes}</p>
        </div>
      )}
    </aside>
  </div>
</Page>

<script>
  import { loadLiveDump } from '../../lib/rootstock-client';
  import { findVerification, cellStateFor, type CellState } from '../../lib/rootstock';

  const statusHtml = (state: CellState, lastError: string | null): string => {
    if (state === 'verified') return '<span class="status-verified">●</span> verified';
    if (state === 'lapsed') return `<span class="status-stale">○</span> ${lastError ? 'errored' : 'lapsed'}`;
    return '<span style="color: var(--ink-3);">n/a</span>';
  };

  loadLiveDump()
    .then((dump) => {
      document.querySelectorAll<HTMLElement>('[data-rs-row]').forEach((tr) => {
        const [cluster, checkpoint] = tr.dataset.rsRow!.split(':');
        const v = findVerification(dump, cluster, checkpoint);
        const state = cellStateFor(v);
        const status = tr.querySelector<HTMLElement>('[data-rs-status]');
        const verified = tr.querySelector<HTMLElement>('[data-rs-verified]');
        if (status) status.innerHTML = statusHtml(state, v?.lastError ?? null);
        if (verified) verified.textContent = v?.verifiedAt ? v.verifiedAt.slice(0, 10) : '—';
      });
    })
    .catch((err) => console.warn('Rootstock live refresh failed', err));
</script>
