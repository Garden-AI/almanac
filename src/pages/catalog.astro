---
import { getCollection, getEntry } from 'astro:content';
import Page from '../layouts/Page.astro';
import { url } from '../lib/url';
import { displayParams } from '../lib/params';
import { yearOf } from '../lib/format';

const allModels = await getCollection('models');
const families = await getCollection('architectures');
const familyName = (id: string) => families.find((f) => f.id === id)?.data.name ?? id;

// Resolve a sort key per model: explicit releaseDate, else first paper's
// published date, else null (sort last).
const enriched = await Promise.all(
  allModels.map(async (m) => {
    let resolvedDate = m.data.releaseDate ?? null;
    if (!resolvedDate) {
      for (const ref of m.data.paperRefs) {
        const p = await getEntry('papers', ref.id);
        if (p?.data.published) {
          resolvedDate = p.data.published;
          break;
        }
      }
    }
    return { model: m, resolvedDate, year: yearOf(resolvedDate) };
  }),
);

const models = enriched.sort((a, b) => {
  if (!a.resolvedDate && !b.resolvedDate) return a.model.data.name.localeCompare(b.model.data.name);
  if (!a.resolvedDate) return 1;
  if (!b.resolvedDate) return -1;
  return b.resolvedDate.localeCompare(a.resolvedDate);
});
---
<Page title="Model Catalog — Garden's Almanac" section="Model Catalog · Index" folioId="§03">
  <div style="text-align: center; margin-top: 6px;">
    <div class="sc" style="font-size: 13px; letter-spacing: 0.16em;">Model Catalog</div>
    <p class="it" style="font-size: 13.5px; color: var(--ink-2); margin-top: 4px;">
      All {models.length} models, most recent first.
    </p>
    <hr class="hairline" style="margin-top: 10px;" />
  </div>

  <div class="detail-body" style="margin-top: 18px;">
    <table class="almanac" style="font-size: 12.5px;">
      <thead>
        <tr>
          <th>Name</th>
          <th>Family</th>
          <th style="text-align: right; width: 80px;">Params</th>
          <th style="text-align: right; width: 60px;">Year</th>
          <th style="width: 24px;" aria-hidden="true"></th>
        </tr>
      </thead>
      <tbody>
        {models.map(({ model: m, year }) => (
          <tr>
            <td><a class="ink-link it" href={url(`/model/${m.id}`)}>{m.data.name}</a></td>
            <td class="sc" style="font-size: 11px;">{familyName(m.data.families[0].id)}</td>
            <td style="text-align: right; font-variant-numeric: tabular-nums;">{displayParams(m.data.checkpoints)}</td>
            <td style="text-align: right; font-variant-numeric: tabular-nums;">{year ?? '—'}</td>
            <td style="text-align: right; color: var(--ink-3);" aria-hidden="true">→</td>
          </tr>
        ))}
      </tbody>
    </table>

    <aside class="detail-rail">
      <div class="margin">
        <span class="label">On reading the map</span>
        <p class="it">
          The <a class="ink-link" href={url('/map')}>map's</a> layout shifts with the reference dataset. A model's
          neighbors on OMat24 may differ from its neighbors on QM9. The catalog entries note both, where it
          matters.
        </p>
      </div>
    </aside>
  </div>
</Page>
