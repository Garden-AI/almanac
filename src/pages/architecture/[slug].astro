---
import { getCollection, getEntry } from 'astro:content';
import Page from '../../layouts/Page.astro';
import { url } from '../../lib/url';
import { displayParams } from '../../lib/params';
import { yearOf } from '../../lib/format';

export async function getStaticPaths() {
  const architectures = await getCollection('architectures');
  const allModels = await getCollection('models');
  return Promise.all(
    architectures.map(async (a) => {
      const matching = allModels.filter((m) =>
        m.data.families.some((ref) => ref.id === a.id),
      );
      const enriched = await Promise.all(
        matching.map(async (m) => {
          let resolvedDate = m.data.releaseDate ?? null;
          if (!resolvedDate) {
            for (const ref of m.data.paperRefs) {
              const p = await getEntry('papers', ref.id);
              if (p?.data.published) { resolvedDate = p.data.published; break; }
            }
          }
          return { model: m, year: yearOf(resolvedDate) };
        }),
      );
      return {
        params: { slug: a.id },
        props: { architecture: a, models: enriched },
      };
    }),
  );
}

const { architecture, models } = Astro.props;
const a = architecture.data;
---
<Page title={`${a.name} — Garden's Almanac`}>
  <p class="sc" style="font-size: 11.5px; letter-spacing: 0.14em;">Architecture family</p>
  <h1>{a.name}</h1>
  <p class="it" style="color: var(--ink-2); font-size: 14px;">{a.descriptor}</p>
  <hr class="title-rule" />

  <div class="detail-body">
    <div>
      <p style="margin-top: 12px;">{a.body}</p>
    </div>
    <aside class="detail-rail">
      <div class="margin">
        <span class="label">Models in this family</span>
        {models.length > 0 ? (
          <table class="almanac fam-table" style="margin-top: 4px;">
            <tbody>
              {models.map(({ model: m, year }) => (
                <tr>
                  <td><a class="ink-link it" href={url(`/model/${m.id}`)}>{m.data.name}</a></td>
                  <td style="text-align: right;">{year ?? '—'}</td>
                  <td style="text-align: right; font-variant-numeric: tabular-nums;">{displayParams(m.data.checkpoints)}</td>
                </tr>
              ))}
            </tbody>
          </table>
        ) : (
          <p class="it">No catalog models in this family yet.</p>
        )}
      </div>
    </aside>
  </div>
</Page>
