---
import { getCollection } from 'astro:content';
import { Code } from 'astro:components';
import Page from '../layouts/Page.astro';
import {
  getRootstockDump,
  findVerification,
  cellStateFor,
  type CellState,
} from '../lib/rootstock';
import { url } from '../lib/url';

// Paper-and-ink syntax theme for the How-To snippet. Ported from
// compatibility.astro. Keeping the colorway aligned with the page tokens.
const almanacCodeTheme = {
  name: 'almanac',
  type: 'light' as const,
  bg: 'rgba(26,22,18,0.035)',
  fg: '#1f1c18',
  settings: [
    { settings: { foreground: '#1f1c18', background: 'rgba(26,22,18,0.035)' } },
    { scope: ['comment', 'comment.line', 'comment.block', 'punctuation.definition.comment'],
      settings: { foreground: '#7a7268', fontStyle: 'italic' } },
    { scope: ['keyword', 'keyword.control', 'keyword.operator.expression', 'storage.type', 'storage.modifier'],
      settings: { foreground: '#7a1f1f' } },
    { scope: ['string', 'string.quoted', 'string.quoted.single', 'string.quoted.double', 'punctuation.definition.string'],
      settings: { foreground: '#5a1414' } },
    { scope: ['constant.numeric', 'constant.language'],
      settings: { foreground: '#5a1414' } },
    { scope: ['entity.name.function', 'support.function', 'meta.function-call.generic'],
      settings: { foreground: '#1f1c18', fontStyle: 'bold' } },
    { scope: ['entity.name.class', 'support.class'],
      settings: { foreground: '#1f1c18', fontStyle: 'bold' } },
    { scope: ['variable.parameter.function-call', 'variable.parameter'],
      settings: { foreground: '#4a4540' } },
    { scope: ['punctuation', 'meta.brace', 'punctuation.separator'],
      settings: { foreground: '#4a4540' } },
  ],
};

const clusters = (await getCollection('clusters')).sort((a, b) => {
  const oa = a.data.order ?? 999;
  const ob = b.data.order ?? 999;
  if (oa !== ob) return oa - ob;
  return a.data.name.localeCompare(b.data.name);
});

const models = await getCollection('models');
const architectures = await getCollection('architectures');
const archName = (id: string): string | null =>
  architectures.find((a) => a.id === id)?.data.name ?? null;

const parseParams = (p: string | undefined): number => {
  if (!p) return NaN;
  const n = parseFloat(p);
  if (Number.isNaN(n)) return NaN;
  return n * (p.endsWith('B') ? 1000 : 1);
};

const dump = await getRootstockDump();

// Cell SVG — keeps the existing app's 14×14 status-mark sizing and hatch
// geometry. The new `dim` flag (for fully-unsupported rows) softens the
// stroke and drops hatch opacity per the handoff's dim treatment.
const cellSvg = (state: CellState, dim: boolean): string => {
  const stroke = dim ? '#a67878' : 'var(--oxblood)';
  if (state === 'verified') {
    return `<svg width="14" height="14" viewBox="0 0 14 14" aria-label="verified"><circle cx="7" cy="7" r="3.6" fill="${stroke}" /></svg>`;
  }
  if (state === 'lapsed') {
    return `<svg width="14" height="14" viewBox="0 0 14 14" aria-label="lapsed"><circle cx="7" cy="7" r="3.4" fill="none" stroke="${stroke}" stroke-width="1" /></svg>`;
  }
  const id = dim ? 'am-hatch-d' : 'am-hatch-n';
  const op = dim ? 0.18 : 0.35;
  return `<svg width="100%" height="14" viewBox="0 0 40 14" preserveAspectRatio="none" aria-label="not applicable" style="display: block;"><defs><pattern id="${id}" patternUnits="userSpaceOnUse" width="5" height="5" patternTransform="rotate(45)"><line x1="0" y1="0" x2="0" y2="5" stroke="var(--ink)" stroke-width="0.5" opacity="${op}" /></pattern></defs><rect x="0" y="3" width="40" height="8" fill="url(#${id})" /></svg>`;
};

// Group: one row per checkpoint, families = one section per model. Families
// sorted alphabetical case-insensitive by display name (per the brief);
// within a family, checkpoint order is the source order from the JSON.
type FamilyRow = {
  checkpointId: string;
  params: string | undefined;
  cells: Array<{ cluster: typeof clusters[number]; state: CellState }>;
  dim: boolean;
};
type FamilyGroup = {
  modelId: string;
  name: string;
  href: string;
  arch: string | null;
  count: number;
  range: string | null;
  rows: FamilyRow[];
};

let counts = { verified: 0, lapsed: 0, na: 0 };
type PerCluster = { verified: number; lapsed: number; na: number };
const perCluster: Record<string, PerCluster> = {};
for (const c of clusters) perCluster[c.id] = { verified: 0, lapsed: 0, na: 0 };

// Every checkpoint gets a row in the DOM regardless of build-time support.
// `hidden` is the build-time guess at "no cluster supports this"; the live
// refresh re-derives it from current Rootstock state. This way the visible
// table is always a function of *live* data, not whatever was true at build.
const families: FamilyGroup[] = models
  .map((m): FamilyGroup => {
    const rows: FamilyRow[] = m.data.checkpoints.map((cp) => {
      const cells = clusters.map((c) => {
        const state: CellState = cellStateFor(findVerification(dump, c.id, cp.id));
        return { cluster: c, state };
      });
      return {
        checkpointId: cp.id,
        params: cp.params,
        cells,
        dim: cells.every((x) => x.state === 'na'),
      };
    });
    const supported = rows.filter((r) => !r.dim);
    for (const r of supported) {
      for (const { cluster, state } of r.cells) {
        counts[state]++;
        perCluster[cluster.id][state]++;
      }
    }
    const sizes = supported
      .map((r) => r.params)
      .filter((s): s is string => !!s);
    let range: string | null = null;
    if (sizes.length) {
      const nums = sizes.map((s) => ({ s, n: parseParams(s) })).filter((x) => !Number.isNaN(x.n));
      if (nums.length) {
        const lo = nums.reduce((a, b) => (a.n <= b.n ? a : b));
        const hi = nums.reduce((a, b) => (a.n >= b.n ? a : b));
        range = lo.s === hi.s ? lo.s : `${lo.s} – ${hi.s}`;
      }
    }
    return {
      modelId: m.id,
      name: m.data.name,
      href: url(`/model/${m.id}`),
      arch: archName(m.data.families[0]?.id ?? ''),
      count: supported.length,
      range,
      rows,
    };
  })
  .sort((a, b) => a.name.toLowerCase().localeCompare(b.name.toLowerCase()));

const totalCheckpoints = families.reduce((acc, f) => acc + f.count, 0);
const colSpan = 2 + clusters.length;

const clusterCards = clusters.map((c) => ({
  id: c.id,
  name: c.data.name,
  inst: c.data.institutionShort ?? c.data.institution.split('·')[0].trim(),
  gpus: c.data.gpu ?? '—',
  counts: perCluster[c.id],
}));

const codeSnippet = `from ase.build import bulk
from rootstock import RootstockCalculator

atoms = bulk("Cu", "fcc", a=3.6) * (5, 5, 5)

with RootstockCalculator(
    cluster="perlmutter",
    checkpoint="mace-mp-0-medium",
    device="cuda",
) as calc:
    atoms.calc = calc
    print(atoms.get_potential_energy())`;
---
<Page title="Garden's Almanac of Matter Models — 2026 Edition" wide>
  <section class="landing-title">
    <p class="sc landing-eyebrow">Garden's</p>
    <h1 class="landing-h1">Almanac of Matter Models</h1>
    <p class="it landing-subtitle">
      A guide to foundation models for molecules, materials, and proteins.
    </p>
  </section>

  <p class="landing-framing">
    The Almanac lists which model checkpoints are installed and verified on shared HPC clusters via
    Rootstock. A
    {' '}<span aria-hidden="true"><svg width="11" height="11" viewBox="0 0 14 14" style="vertical-align: -1px;"><circle cx="7" cy="7" r="3.4" fill="var(--oxblood)" /></svg></span>
    {' '}<span class="it" style="color: var(--ink-2);">filled circle</span> means verified in the last seven days; an
    {' '}<span aria-hidden="true"><svg width="11" height="11" viewBox="0 0 14 14" style="vertical-align: -1px;"><circle cx="7" cy="7" r="3" fill="none" stroke="var(--oxblood)" stroke-width="1" /></svg></span>
    {' '}<span class="it" style="color: var(--ink-2);">open circle</span> means the check has lapsed; a hatched
    cell means the model isn't supported on that cluster.
  </p>

  {/* MOBILE: per-cluster cards stand in for the matrix below 720px. */}
  <section class="cluster-cards" aria-label="Clusters">
    {clusterCards.map((c) => (
      <a class="cluster-card" href={url(`/cluster/${c.id}`)}>
        <span class="cc-arrow" aria-hidden="true">→</span>
        <div class="cc-name">{c.name}</div>
        <span class="cc-inst">{c.inst}</span>
        <dl class="cc-row">
          <dt>GPU types</dt>
          <dd>{c.gpus}</dd>
        </dl>
        <div class="cc-status">
          <span><span style="color: var(--oxblood);">●</span> <span data-rs-cluster-count={`${c.id}:verified`}>{c.counts.verified}</span> verified</span>
          <span style="color: var(--ink-2);">○ <span data-rs-cluster-count={`${c.id}:lapsed`}>{c.counts.lapsed}</span> lapsed</span>
          <span class="it">// <span data-rs-cluster-count={`${c.id}:na`}>{c.counts.na}</span> not applicable</span>
        </div>
      </a>
    ))}
  </section>

  {/* DESKTOP: the matrix is the centrepiece. */}
  <section class="am-wrap">
    <table class="almanac am-table" aria-label="Availability matrix">
      <colgroup>
        <col class="am-col-slug" />
        <col class="am-col-size" />
        {clusters.map((c) => <col class="am-col-cluster" data-cluster={c.id} />)}
      </colgroup>
      <thead>
        <tr>
          <th class="am-th-slug">Checkpoint</th>
          <th class="am-th-size">Size</th>
          {clusters.map((c) => (
            <th class="am-th-cluster">
              <div class="am-th-cluster-name">
                <a class="ink-link" href={url(`/cluster/${c.id}`)}>{c.data.name}</a>
              </div>
              <div class="sc am-th-cluster-inst">
                {c.data.institutionShort ?? c.data.institution.split('·')[0].trim()}
              </div>
              <div class="mono am-th-cluster-gpu">
                {c.data.gpu ?? '—'}
              </div>
            </th>
          ))}
        </tr>
      </thead>
      <tbody>
        {families.map((fam) => (
          <>
            <tr class:list={["am-fhead", fam.count === 0 && "am-hidden"]} data-rs-family={fam.modelId}>
              <td colspan={colSpan}>
                <div class="am-fhead-inner">
                  <a class="am-fhead-name" href={fam.href}>
                    <span class="am-fhead-name-text">{fam.name}</span>
                    <span class="am-fhead-arrow" aria-hidden="true">→</span>
                  </a>
                  <span class="am-fhead-meta">
                    <span>
                      <span data-rs-family-count={fam.modelId}>{fam.count}</span>
                      {' '}checkpoint<span data-rs-family-plural={fam.modelId}>{fam.count === 1 ? '' : 's'}</span>
                    </span>
                    {fam.range ? (<><span class="am-dot">·</span><span class="mono">{fam.range}</span></>) : null}
                    {fam.arch ? (<><span class="am-dot">·</span><span class="it">{fam.arch}</span></>) : null}
                  </span>
                </div>
              </td>
            </tr>
            {fam.rows.map((r) => (
              <tr class:list={["am-row", r.dim && "am-hidden"]} data-rs-row={r.checkpointId} data-rs-family-id={fam.modelId}>
                <td class="am-slug">
                  <a class="am-slug-link" href={`${fam.href}#${r.checkpointId}`}>{r.checkpointId}</a>
                </td>
                <td class="am-size">{r.params ?? '—'}</td>
                {r.cells.map(({ cluster, state }) => (
                  <td class="am-cell" data-rs-cell={`${cluster.id}:${r.checkpointId}`} set:html={cellSvg(state, r.dim)} />
                ))}
              </tr>
            ))}
          </>
        ))}
      </tbody>
    </table>

    <div class="am-caption">
      <span class="it">
        <span data-rs-count="total">{totalCheckpoints}</span> checkpoints · {clusters.length} clusters ·
        {' '}<span data-rs-count="verified">{counts.verified}</span> verified,
        {' '}<span data-rs-count="lapsed">{counts.lapsed}</span> lapsed,
        {' '}<span data-rs-count="na">{counts.na}</span> not applicable
      </span>
      <span class="am-legend">
        <span class="am-legend-item">
          <svg width="12" height="12" viewBox="0 0 14 14"><circle cx="7" cy="7" r="3.6" fill="var(--oxblood)" /></svg>
          <span class="sc">Verified</span>
        </span>
        <span class="am-legend-item">
          <svg width="12" height="12" viewBox="0 0 14 14"><circle cx="7" cy="7" r="3.4" fill="none" stroke="var(--oxblood)" stroke-width="1" /></svg>
          <span class="sc">Lapsed</span>
        </span>
        <span class="am-legend-item">
          <svg width="14" height="6" viewBox="0 0 14 6">
            <defs>
              <pattern id="am-lg-hatch" patternUnits="userSpaceOnUse" width="5" height="5" patternTransform="rotate(45)">
                <line x1="0" y1="0" x2="0" y2="5" stroke="#1f1c18" stroke-width="0.5" opacity="0.45" />
              </pattern>
            </defs>
            <rect x="0" y="0" width="14" height="6" fill="url(#am-lg-hatch)" />
          </svg>
          <span class="sc">Not supported</span>
        </span>
      </span>
    </div>
  </section>

  <section class="howto">
    <div class="sc howto-head">How do I use these models?</div>
    <div class="howto-grid">
      <div class="howto-prose">
        <p>
          Install <code class="mono">rootstock</code> with <code class="mono">pip</code> or
          {' '}<code class="mono">uv</code>, then plug a
          {' '}<code class="mono">RootstockCalculator</code> in wherever you'd reach for an ASE calculator.
        </p>
        <p>
          <span class="sc howto-further">Further →</span>
        </p>
        <p>
          <a class="ink-link" href="https://garden-ai.github.io/rootstock/">Rootstock docs</a>
          <span class="it" style="color: var(--ink-2);"> — LAMMPS integration and fine-tuning notes.</span>
        </p>
        <p>
          <a class="ink-link" href="https://gitlab.osti.gov/genesis/genesis-skills/-/tree/main/skills/modcon-skills">DOE agent skills</a>
          <span class="it" style="color: var(--ink-2);"> — skills to run on DOE clusters with agents (incl. Academy).</span>
        </p>
      </div>
      <Code code={codeSnippet} lang="python" theme={almanacCodeTheme} />
    </div>
  </section>
</Page>

<style>
  /* Title block — left-aligned, single column, no woodcut. */
  .landing-title { margin-top: 8px; }
  .landing-eyebrow {
    font-size: 12.5px;
    letter-spacing: 0.16em;
    color: var(--ink-2);
    margin: 0 0 4px;
  }
  .landing-h1 {
    font-family: var(--serif);
    font-size: 52px;
    line-height: 1.02;
    letter-spacing: -0.012em;
    font-weight: 600;
    margin: 0;
    text-wrap: balance;
    max-width: 720px;
  }
  .landing-subtitle {
    font-size: 18px;
    line-height: 1.4;
    color: var(--ink-2);
    margin: 8px 0 0;
    max-width: 640px;
  }

  .landing-framing {
    font-size: 14.5px;
    line-height: 1.55;
    color: var(--ink);
    margin: 22px 0 0;
    max-width: 820px;
  }

  /* Availability matrix — one row per checkpoint, grouped by family section header.
   * Ported from design_handoff_availability_table/availability-matrix.css; sizing
   * for the slug column, status marks, and cluster headers stays at the existing
   * app's values where this overlaps with prior matrix styling. */
  .am-wrap { margin-top: 24px; }
  .am-table { table-layout: auto; width: 100%; }
  .am-table thead th { padding-top: 8px; padding-bottom: 6px; }
  /* Body rows use the existing app's tight row height; the family-header row
     (`.am-fhead td`) needs a more-specific selector to escape this rule. */
  .am-table tbody td { padding-top: 3px; padding-bottom: 3px; }
  .am-col-size { width: 64px; }
  .am-col-cluster { width: 1%; }
  .am-table thead th.am-th-cluster { min-width: 140px; text-align: center; vertical-align: bottom; padding: 6px 4px; line-height: 1.2; }
  .am-th-cluster-name { font-family: var(--smallcaps); font-size: 12.5px; letter-spacing: 0.06em; color: var(--ink); }
  .am-th-cluster-inst { font-size: 9.5px; letter-spacing: 0.10em; color: var(--ink-2); margin-top: 1px; }
  .am-th-cluster-gpu { font-size: 9px; color: var(--ink-3); margin-top: 2px; letter-spacing: 0.02em; }
  .am-th-slug { text-align: left; }
  .am-th-size { text-align: right; }

  .am-row .am-slug {
    font-family: var(--mono);
    font-size: 11px;
    padding-left: 12px;
    color: var(--ink);
    word-break: break-all;
  }
  .am-slug-link {
    color: inherit;
    text-decoration: none;
    border-bottom: 0.5px solid transparent;
    transition: color .12s, border-color .12s;
  }
  .am-row:hover .am-slug-link {
    color: var(--oxblood);
    border-bottom-color: var(--oxblood);
  }
  .am-row .am-size {
    text-align: right;
    font-variant-numeric: tabular-nums;
    font-size: 12px;
    color: var(--ink-2);
  }
  .am-row .am-cell {
    text-align: center;
    padding: 3px 0;
    position: relative;
  }

  /* Rows/family-headers hidden because no cluster currently supports them.
     Build-time render applies this from the fixture/live data; the runtime
     refresh re-applies it from current Rootstock state — so the matrix
     reflects live truth even when the build is stale. */
  .am-hidden { display: none; }

  /* Family section header — one TD spanning all columns, hairline above and below.
     `tbody tr.am-fhead td` beats the `tbody td` body-row padding rule above. */
  .am-table tbody tr.am-fhead td {
    border-right: 0;
    background: transparent;
    padding: 12px 8px 5px;
    border-bottom: 0.5px solid var(--rule);
    border-top: 0.5px solid var(--rule);
  }
  .am-fhead-inner {
    display: flex;
    align-items: baseline;
    justify-content: space-between;
    gap: 16px;
    flex-wrap: wrap;
  }
  .am-fhead-name {
    font-family: var(--smallcaps);
    font-size: 14px;
    letter-spacing: 0.10em;
    color: var(--ink);
    text-decoration: none;
    display: inline-flex;
    align-items: baseline;
    gap: 8px;
    white-space: nowrap;
  }
  .am-fhead-name:hover,
  .am-fhead-name:hover .am-fhead-arrow { color: var(--oxblood); }
  .am-fhead-arrow {
    color: var(--ink-3);
    font-family: var(--serif);
    letter-spacing: 0;
    font-size: 14px;
  }
  .am-fhead-meta {
    font-family: var(--serif);
    font-size: 12px;
    color: var(--ink-3);
    display: inline-flex;
    align-items: baseline;
    gap: 6px;
    white-space: nowrap;
  }
  .am-fhead-meta .am-dot { color: var(--ink-3); opacity: 0.6; }
  .am-fhead-meta .mono   { font-size: 11px; color: var(--ink-2); }
  .am-fhead-meta .it     { color: var(--ink-2); }

  /* Caption + legend on one baseline. */
  .am-caption {
    display: flex;
    justify-content: space-between;
    align-items: baseline;
    margin-top: 10px;
    font-size: 11.5px;
    color: var(--ink-2);
    gap: 12px;
    flex-wrap: wrap;
  }
  .am-legend { display: inline-flex; align-items: center; white-space: nowrap; }
  .am-legend-item { display: inline-flex; align-items: center; gap: 5px; margin-left: 14px; }
  .am-legend-item .sc { font-size: 10.5px; letter-spacing: 0.08em; color: var(--ink-2); }

  /* How-to block — full width below the matrix; two-column on desktop. */
  .howto { margin-top: 32px; }
  .howto-head {
    font-size: 11.5px;
    letter-spacing: 0.14em;
    color: var(--ink);
    margin-bottom: 10px;
  }
  .howto-grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 28px;
    align-items: start;
  }
  .howto-prose {
    font-size: 13.5px;
    line-height: 1.55;
    color: var(--ink);
  }
  .howto-prose p { margin: 0 0 8px; }
  .howto-prose p:last-child { margin-bottom: 0; }
  .howto-further {
    font-size: 10.5px;
    letter-spacing: 0.10em;
    color: var(--ink-2);
  }
  .howto :global(pre) {
    margin: 0;
    font-family: var(--mono);
    font-size: 10.75px;
    line-height: 1.5;
    padding: 10px 12px;
    overflow-x: auto;
    white-space: pre;
    background: rgba(26, 22, 18, 0.035);
    border-left: 1.5px solid var(--oxblood);
  }

  /* Mobile cluster cards (≤720px) — net-new component. */
  .cluster-cards { display: none; margin-top: 22px; }
  .cluster-card {
    display: block;
    text-decoration: none;
    color: var(--ink);
    border-top: 1.5px solid var(--ink);
    border-bottom: 0.5px solid var(--ink);
    padding: 18px 4px 16px;
    background: transparent;
    position: relative;
  }
  .cluster-card + .cluster-card { border-top: 0.5px solid var(--rule); }
  .cluster-card .cc-name {
    font-family: var(--serif);
    font-size: 26px;
    line-height: 1.0;
    font-weight: 600;
    letter-spacing: -0.005em;
  }
  .cluster-card .cc-inst {
    font-family: var(--smallcaps);
    font-size: 11px;
    letter-spacing: 0.10em;
    color: var(--ink-2);
    margin-top: 6px;
    display: block;
  }
  .cluster-card .cc-row {
    display: grid;
    grid-template-columns: auto 1fr;
    column-gap: 10px;
    row-gap: 3px;
    margin: 10px 0 0;
    font-size: 13.5px;
  }
  .cluster-card .cc-row dt {
    font-family: var(--smallcaps);
    font-size: 10.5px;
    letter-spacing: 0.10em;
    color: var(--ink-3);
    padding-top: 2px;
    margin: 0;
  }
  .cluster-card .cc-row dd { margin: 0; color: var(--ink); }
  .cluster-card .cc-status {
    margin-top: 12px;
    display: flex;
    flex-wrap: wrap;
    gap: 4px 14px;
    font-size: 12.5px;
  }
  .cluster-card .cc-status .it { color: var(--ink-2); }
  .cluster-card .cc-arrow {
    position: absolute;
    right: 4px;
    top: 18px;
    color: var(--oxblood);
    font-family: var(--serif);
    font-size: 18px;
  }
  .cluster-card:hover .cc-name { color: var(--oxblood); }

  @media (max-width: 720px) {
    .am-wrap { display: none; }
    .cluster-cards { display: block; }
    .landing-h1 { font-size: 34px; }
    .landing-subtitle { font-size: 16px; }
    .howto-grid { grid-template-columns: 1fr; gap: 16px; }
  }
</style>

<script>
  import { loadLiveDump } from '../lib/rootstock-client';
  import { findVerification, cellStateFor, type CellState } from '../lib/rootstock';

  const cellSvg = (state: CellState): string => {
    if (state === 'verified') {
      return `<svg width="14" height="14" viewBox="0 0 14 14" aria-label="verified"><circle cx="7" cy="7" r="3.6" fill="var(--oxblood)" /></svg>`;
    }
    if (state === 'lapsed') {
      return `<svg width="14" height="14" viewBox="0 0 14 14" aria-label="lapsed"><circle cx="7" cy="7" r="3.4" fill="none" stroke="var(--oxblood)" stroke-width="1" /></svg>`;
    }
    return `<svg width="100%" height="14" viewBox="0 0 40 14" preserveAspectRatio="none" aria-label="not applicable" style="display: block;"><defs><pattern id="am-hatch-n" patternUnits="userSpaceOnUse" width="5" height="5" patternTransform="rotate(45)"><line x1="0" y1="0" x2="0" y2="5" stroke="var(--ink)" stroke-width="0.5" opacity="0.35" /></pattern></defs><rect x="0" y="3" width="40" height="8" fill="url(#am-hatch-n)" /></svg>`;
  };

  // Re-derive visibility purely from live data. Whatever the build baked in
  // gets overwritten — that's the point. A stale build can't strand rows.
  loadLiveDump()
    .then((dump) => {
      const counts = { verified: 0, lapsed: 0, na: 0 };
      const familySupportedCount: Record<string, number> = {};
      const perCluster: Record<string, { verified: number; lapsed: number; na: number }> = {};
      const rows = document.querySelectorAll<HTMLElement>('[data-rs-row]');
      rows.forEach((tr) => {
        const tdCells = tr.querySelectorAll<HTMLElement>('[data-rs-cell]');
        const cellInfo: Array<{ cluster: string; state: CellState }> = [];
        tdCells.forEach((td) => {
          const [cluster, checkpoint] = td.dataset.rsCell!.split(':');
          cellInfo.push({ cluster, state: cellStateFor(findVerification(dump, cluster, checkpoint)) });
        });
        const states = cellInfo.map((x) => x.state);
        const allNa = states.every((s) => s === 'na');
        const famId = tr.dataset.rsFamilyId ?? '';
        familySupportedCount[famId] = (familySupportedCount[famId] ?? 0) + (allNa ? 0 : 1);
        tr.classList.toggle('am-hidden', allNa);
        if (!allNa) {
          for (const { cluster, state } of cellInfo) {
            counts[state]++;
            (perCluster[cluster] ??= { verified: 0, lapsed: 0, na: 0 })[state]++;
          }
          tdCells.forEach((td, i) => { td.innerHTML = cellSvg(states[i]); });
        }
      });
      document.querySelectorAll<HTMLElement>('[data-rs-cluster-count]').forEach((el) => {
        const [cluster, metric] = el.dataset.rsClusterCount!.split(':') as [string, 'verified' | 'lapsed' | 'na'];
        el.textContent = String(perCluster[cluster]?.[metric] ?? 0);
      });
      document.querySelectorAll<HTMLElement>('[data-rs-family]').forEach((tr) => {
        const famId = tr.dataset.rsFamily ?? '';
        tr.classList.toggle('am-hidden', (familySupportedCount[famId] ?? 0) === 0);
      });
      document.querySelectorAll<HTMLElement>('[data-rs-family-count]').forEach((el) => {
        const famId = el.dataset.rsFamilyCount ?? '';
        el.textContent = String(familySupportedCount[famId] ?? 0);
      });
      document.querySelectorAll<HTMLElement>('[data-rs-family-plural]').forEach((el) => {
        const famId = el.dataset.rsFamilyPlural ?? '';
        el.textContent = (familySupportedCount[famId] ?? 0) === 1 ? '' : 's';
      });
      document.querySelectorAll<HTMLElement>('[data-rs-count]').forEach((el) => {
        const k = el.dataset.rsCount as keyof typeof counts | 'total';
        if (k === 'total') {
          el.textContent = String(counts.verified + counts.lapsed + counts.na);
          return;
        }
        el.textContent = String(counts[k]);
      });
    })
    .catch((err) => console.warn('Rootstock live refresh failed', err));
</script>
