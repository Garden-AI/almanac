---
import { getCollection } from 'astro:content';
import { Code } from 'astro:components';
import Page from '../layouts/Page.astro';
import {
  getRootstockDump,
  findVerification,
  cellStateFor,
  cellSvg,
  type CellState,
} from '../lib/rootstock';
import { url } from '../lib/url';

// Paper-and-ink syntax theme for the How-To snippet. Ported from
// compatibility.astro. Keeping the colorway aligned with the page tokens.
const almanacCodeTheme = {
  name: 'almanac',
  type: 'light' as const,
  bg: 'rgba(26,22,18,0.035)',
  fg: '#1f1c18',
  settings: [
    { settings: { foreground: '#1f1c18', background: 'rgba(26,22,18,0.035)' } },
    { scope: ['comment', 'comment.line', 'comment.block', 'punctuation.definition.comment'],
      settings: { foreground: '#7a7268', fontStyle: 'italic' } },
    { scope: ['keyword', 'keyword.control', 'keyword.operator.expression', 'storage.type', 'storage.modifier'],
      settings: { foreground: '#7a1f1f' } },
    { scope: ['string', 'string.quoted', 'string.quoted.single', 'string.quoted.double', 'punctuation.definition.string'],
      settings: { foreground: '#5a1414' } },
    { scope: ['constant.numeric', 'constant.language'],
      settings: { foreground: '#5a1414' } },
    { scope: ['entity.name.function', 'support.function', 'meta.function-call.generic'],
      settings: { foreground: '#1f1c18', fontStyle: 'bold' } },
    { scope: ['entity.name.class', 'support.class'],
      settings: { foreground: '#1f1c18', fontStyle: 'bold' } },
    { scope: ['variable.parameter.function-call', 'variable.parameter'],
      settings: { foreground: '#4a4540' } },
    { scope: ['punctuation', 'meta.brace', 'punctuation.separator'],
      settings: { foreground: '#4a4540' } },
  ],
};

const clusters = (await getCollection('clusters')).sort((a, b) => {
  const oa = a.data.order ?? 999;
  const ob = b.data.order ?? 999;
  if (oa !== ob) return oa - ob;
  return a.data.name.localeCompare(b.data.name);
});

const models = await getCollection('models');

const dump = await getRootstockDump();

// Group: one row per checkpoint, families = one section per model. Families
// sorted alphabetical case-insensitive by display name (per the brief);
// within a family, checkpoint order is the source order from the JSON.
type FamilyRow = {
  checkpointId: string;
  cells: Array<{ cluster: typeof clusters[number]; state: CellState }>;
  dim: boolean;
};
type FamilyGroup = {
  modelId: string;
  name: string;
  href: string;
  count: number;
  rows: FamilyRow[];
};

type PerCluster = { verified: number; lapsed: number; na: number };
const perCluster: Record<string, PerCluster> = {};
for (const c of clusters) perCluster[c.id] = { verified: 0, lapsed: 0, na: 0 };

// Every checkpoint gets a row in the DOM regardless of build-time support.
// `hidden` is the build-time guess at "no cluster supports this"; the live
// refresh re-derives it from current Rootstock state. This way the visible
// table is always a function of *live* data, not whatever was true at build.
const families: FamilyGroup[] = models
  .map((m): FamilyGroup => {
    const rows: FamilyRow[] = m.data.checkpoints.map((cp) => {
      const cells = clusters.map((c) => {
        const state: CellState = cellStateFor(findVerification(dump, c.id, cp.id));
        return { cluster: c, state };
      });
      return {
        checkpointId: cp.id,
        cells,
        dim: cells.every((x) => x.state === 'na'),
      };
    });
    const supported = rows.filter((r) => !r.dim);
    for (const r of supported) {
      for (const { cluster, state } of r.cells) {
        perCluster[cluster.id][state]++;
      }
    }
    return {
      modelId: m.id,
      name: m.data.name,
      href: url(`/model/${m.id}`),
      count: supported.length,
      rows,
    };
  })
  .sort((a, b) => a.name.toLowerCase().localeCompare(b.name.toLowerCase()));

const colSpan = 1 + clusters.length;

const clusterCards = clusters.map((c) => ({
  id: c.id,
  name: c.data.name,
  inst: c.data.institutionShort ?? c.data.institution.split('·')[0].trim(),
  gpus: c.data.gpu ?? '—',
  counts: perCluster[c.id],
}));

const codeSnippet = `# Running on perlmutter
from ase.build import bulk
from rootstock import RootstockCalculator

atoms = bulk("Cu", "fcc", a=3.6) * (5, 5, 5)

with RootstockCalculator(
    cluster="perlmutter",
    checkpoint="mace-mp-0-medium",
    device="cuda",
) as calc:
    atoms.calc = calc
    print(atoms.get_potential_energy())`;
---
<Page title="Garden's Almanac of Matter Models — 2026 Edition">
  <section class="landing-title">
    <p class="sc landing-eyebrow">Garden's</p>
    <h1 class="landing-h1">Almanac of Matter Models</h1>
    <p class="landing-subtitle">
      A field guide to matter models, starting with machine-learned interatomic potentials pre-installed on shared HPC clusters.
      {' '}<a class="ink-link" href="https://garden-ai.github.io/rootstock/">Rootstock</a> lets you
      run any MLIP through a drop-in ASE calculator.
    </p>
    <nav class="landing-cta" aria-label="Getting started">
      <a class="ink-link" href="https://garden-ai.github.io/rootstock/run-python/">Run with ASE</a>
      <span class="landing-cta-sep" aria-hidden="true"></span>
      <a class="ink-link" href="https://garden-ai.github.io/rootstock/run-tools/">Integrate with Other Tools</a>
      <span class="landing-cta-sep" aria-hidden="true"></span>
      <a class="ink-link" href="https://garden-ai.github.io/rootstock/run-agents/">Run with an Agent</a>
    </nav>
  </section>

  {/* MOBILE: per-cluster cards stand in for the matrix below 720px. */}
  <section class="cluster-cards" aria-label="Clusters">
    {clusterCards.map((c) => (
      <a class="cluster-card" href={url(`/clusters#${c.id}`)}>
        <span class="cc-arrow" aria-hidden="true">→</span>
        <div class="cc-name">{c.name}</div>
        <span class="cc-inst">{c.inst}</span>
        <dl class="cc-row">
          <dt>GPU types</dt>
          <dd>{c.gpus}</dd>
        </dl>
        <div class="cc-status">
          <span><span style="color: var(--oxblood);">●</span> <span data-rs-cluster-count={`${c.id}:verified`}>{c.counts.verified}</span> verified</span>
          <span style="color: var(--ink-2);">○ <span data-rs-cluster-count={`${c.id}:lapsed`}>{c.counts.lapsed}</span> lapsed</span>
          <span class="it">// <span data-rs-cluster-count={`${c.id}:na`}>{c.counts.na}</span> not applicable</span>
        </div>
      </a>
    ))}
  </section>

  {/* DESKTOP: the matrix is the centrepiece. */}
  <section class="am-wrap">
    <div class="am-controls">
      <div class="am-search-box" role="search" aria-label="Search availability matrix">
        <label class="am-search-wrap">
          <span class="am-control-icon" aria-hidden="true">
            <svg width="14" height="14" viewBox="0 0 16 16">
              <circle cx="7" cy="7" r="4.25" fill="none" stroke="currentColor" stroke-width="1.2" />
              <path d="M10.2 10.2L13.2 13.2" fill="none" stroke="currentColor" stroke-width="1.2" stroke-linecap="round" />
            </svg>
          </span>
          <input
            class="am-search"
            data-am-search
            type="search"
            aria-label="Search models"
            placeholder="Search models, e.g., equiformer, escn..."
            autocomplete="off"
          />
        </label>
      </div>
      <details class="am-key">
        <summary class="am-key-summary">
          <span class="am-key-head">
            How we verify models
            <span class="am-key-caret" aria-hidden="true">▸</span>
          </span>
          <span class="status-key am-key-compact">
            <span class="status-key-item">
              <svg width="14" height="14" viewBox="0 0 14 14" aria-hidden="true"><circle cx="7" cy="7" r="3.6" fill="var(--oxblood)" /></svg>
              <span class="sc">verified</span>
            </span>
            <span class="status-key-item">
              <svg width="14" height="14" viewBox="0 0 14 14" aria-hidden="true"><circle cx="7" cy="7" r="3.4" fill="none" stroke="var(--oxblood)" stroke-width="1" /></svg>
              <span class="sc">lapsed</span>
            </span>
            <span class="status-key-item">
              <svg width="30" height="15" viewBox="0 0 30 15" aria-hidden="true"><defs><pattern id="am-key-hatch-1" patternUnits="userSpaceOnUse" width="7" height="7" patternTransform="rotate(45)"><line x1="0" y1="0" x2="0" y2="7" stroke="var(--ink)" stroke-width="0.9" opacity="0.45" /></pattern></defs><rect x="0" y="0" width="30" height="15" fill="url(#am-key-hatch-1)" /></svg>
              <span class="sc">not supported</span>
            </span>
          </span>
        </summary>
        <dl class="am-key-glossary">
          <div class="am-key-row">
            <dt><svg width="14" height="14" viewBox="0 0 14 14" aria-hidden="true"><circle cx="7" cy="7" r="3.6" fill="var(--oxblood)" /></svg><span class="sc">verified</span></dt>
            <dd>Run from Rootstock on this cluster in the last 30 days.</dd>
          </div>
          <div class="am-key-row">
            <dt><svg width="14" height="14" viewBox="0 0 14 14" aria-hidden="true"><circle cx="7" cy="7" r="3.4" fill="none" stroke="var(--oxblood)" stroke-width="1" /></svg><span class="sc">lapsed</span></dt>
            <dd>Installed here, but not verified in the last 30 days.</dd>
          </div>
          <div class="am-key-row">
            <dt><svg width="30" height="15" viewBox="0 0 30 15" aria-hidden="true"><defs><pattern id="am-key-hatch-2" patternUnits="userSpaceOnUse" width="7" height="7" patternTransform="rotate(45)"><line x1="0" y1="0" x2="0" y2="7" stroke="var(--ink)" stroke-width="0.9" opacity="0.45" /></pattern></defs><rect x="0" y="0" width="30" height="15" fill="url(#am-key-hatch-2)" /></svg><span class="sc">not supported</span></dt>
            <dd>Not installed on this cluster.</dd>
          </div>
        </dl>
      </details>
    </div>

    <table class="almanac am-table" aria-label="Availability matrix">
      <colgroup>
        <col class="am-col-slug" />
        {clusters.map((c) => <col class="am-col-cluster" data-cluster={c.id} />)}
      </colgroup>
      <thead>
        <tr>
          <th class="am-th-slug">
            <span class="am-th-slug-fam">Model family</span>
            <span class="am-th-slug-cp">checkpoint</span>
          </th>
          {clusters.map((c) => (
            <th class="am-th-cluster">
              <a class="am-cluster-link" href={url(`/clusters#${c.id}`)}>{c.data.name}</a>
              <div class="mono am-th-cluster-gpu">{c.data.gpu ?? '—'}</div>
            </th>
          ))}
        </tr>
      </thead>
      <tbody>
        {families.map((fam) => (
          <>
            <tr
              class:list={["am-fhead", fam.count === 0 && "am-hidden"]}
              data-rs-family={fam.modelId}
              data-am-family={fam.modelId}
            >
              <td colspan={colSpan}>
                <div class="am-fhead-inner">
                  <a class="am-fhead-name" href={fam.href}>{fam.name}</a>
                </div>
              </td>
            </tr>
            {fam.rows.map((r) => (
              <tr
                class:list={["am-row", r.dim && "am-hidden"]}
                data-rs-row={r.checkpointId}
                data-rs-family-id={fam.modelId}
                data-am-family={fam.modelId}
                data-am-search={`${fam.name} ${r.checkpointId}`.toLowerCase()}
              >
                <td class="am-slug">
                  <a class="am-slug-link" href={`${fam.href}#${r.checkpointId}`}>{r.checkpointId}</a>
                </td>
                {r.cells.map(({ cluster, state }) => (
                  <td
                    class="am-cell"
                    data-rs-cell={`${cluster.id}:${r.checkpointId}`}
                    set:html={cellSvg(state, r.dim)}
                  />
                ))}
              </tr>
            ))}
          </>
        ))}
      </tbody>
    </table>
  </section>

  <section class="howto">
    <div class="howto-grid">
      <div class="howto-prose">
        <h2 class="howto-head">Swap models without managing environments</h2>
        <p>
          Admins pre-install each MLIP in its own isolated environment.
          You just need to install the thin <code>rootstock</code> Python package, which runs the
          model in a subprocess and gives you an ASE calculator that talks to it.
          You can swap between all the models supported on a cluster without changing your dependencies.
        </p>
      </div>
      <Code code={codeSnippet} lang="python" theme={almanacCodeTheme} />
    </div>
  </section>
</Page>

<style>
  /* Title block — left-aligned, single column, no woodcut. */
  .landing-title { margin-top: 8px; }
  .landing-eyebrow {
    font-size: var(--fs-xl);
    letter-spacing: var(--track-display);
    color: var(--ink-2);
    margin: 0 0 6px;
  }
  .landing-h1 {
    font-family: var(--serif);
    font-size: var(--fs-display);
    line-height: 1.0;
    letter-spacing: -0.012em;
    font-weight: 600;
    margin: 0;
    text-wrap: balance;
    max-width: 720px;
  }
  .landing-subtitle {
    font-size: var(--fs-xl);
    line-height: 1.4;
    color: var(--ink);
    margin: 14px 0 0;
    max-width: 840px;
  }
  .landing-cta {
    display: flex;
    align-items: center;
    flex-wrap: wrap;
    gap: 8px 18px;
    margin-top: 16px;
    font-size: var(--fs-lg);
  }
  .landing-cta-sep {
    width: 1px;
    height: 15px;
    background: var(--rule-soft);
  }

  .status-key {
    display: inline-flex;
    align-items: center;
    flex-wrap: wrap;
    gap: 6px 18px;
    font-size: var(--fs-lg);
    line-height: 1.25;
    color: var(--ink);
  }
  .status-key-item {
    display: inline-flex;
    align-items: center;
    gap: 8px;
  }

  /* Progressive disclosure: collapsed shows the compact key under a "How we
     verify models" header; expanding swaps that key for the full glossary
     (glyph + label + definition), so the states are never shown twice at once.
     Flat, no elevation (paper-and-ink), zero-JS via <details>. */
  .am-key { text-align: right; }
  .am-key-summary {
    display: flex;
    flex-direction: column;
    align-items: flex-end;       /* header on top, key beneath — right-aligned */
    gap: 7px;
    cursor: pointer;
    list-style: none;
    outline: none;
  }
  .am-key:not([open]) .am-key-summary { min-height: 38px; justify-content: center; }
  .am-key-summary::-webkit-details-marker { display: none; }
  .am-key-head {
    display: inline-flex;
    align-items: center;
    gap: 7px;
    font-family: var(--smallcaps);
    text-transform: lowercase;
    letter-spacing: var(--track-label);
    font-size: var(--fs-md);
    color: var(--ink);
    transition: color 0.12s;
  }
  .am-key-caret {
    font-family: var(--serif);
    font-size: var(--fs-xs);
    color: var(--ink-3);
    transition: transform 0.15s, color 0.12s;
  }
  .am-key[open] .am-key-caret { transform: rotate(90deg); }
  .am-key-summary:hover .am-key-head,
  .am-key-summary:hover .am-key-caret { color: var(--oxblood); }
  .am-key-summary:focus-visible .am-key-head {
    color: var(--oxblood);
    text-decoration: underline;
    text-underline-offset: 3px;
  }
  .am-key[open] .am-key-compact { display: none; }
  .am-key-glossary {
    display: grid;
    gap: 7px 0;
    max-width: 460px;
    margin: 10px 0 2px auto;     /* hang under the header, right-aligned block */
    text-align: left;
  }
  .am-key-row {
    display: grid;
    grid-template-columns: auto 1fr;
    gap: 12px;
    align-items: baseline;
  }
  .am-key-row dt {
    display: inline-flex;
    align-items: center;
    gap: 8px;
    white-space: nowrap;
  }
  .am-key-row dd {
    margin: 0;
    font-size: var(--fs-md);
    line-height: 1.4;
    color: var(--ink-2);
  }

  /* Availability matrix — one row per checkpoint, grouped by family section header.
   * Ported from design_handoff_availability_table/availability-matrix.css; sizing
   * for the slug column, status marks, and cluster headers stays at the existing
   * app's values where this overlaps with prior matrix styling. */
  .am-wrap { margin-top: 24px; }
  .am-controls {
    display: flex;
    align-items: flex-start;
    justify-content: space-between;
    flex-wrap: wrap;
    gap: 12px 28px;
    margin-bottom: 18px;
  }
  .am-search-box {
    flex: 1 1 340px;
    min-width: 0;
  }
  .am-search-wrap {
    display: block;
    position: relative;
    min-width: 0;
  }
  .am-search {
    box-sizing: border-box;
    width: 100%;
    min-height: 38px;
    padding: 9px 12px 9px 34px;
    border: 0.5px solid var(--rule-soft);
    border-radius: 4px;
    background: rgba(250, 247, 241, 0.72);
    color: var(--ink);
    font-family: var(--serif);
    font-size: var(--fs-md);
    line-height: 1.2;
    transition: border-color 0.14s, background 0.14s;
  }
  .am-search::placeholder {
    color: var(--ink-3);
    opacity: 0.78;
  }
  .am-control-icon {
    color: var(--ink-3);
    display: inline-flex;
    align-items: center;
    justify-content: center;
    flex: 0 0 auto;
  }
  .am-search-wrap .am-control-icon {
    position: absolute;
    left: 12px;
    top: 50%;
    transform: translateY(-50%);
    pointer-events: none;
  }
  .am-search:focus {
    outline: 0;
    border-color: rgba(122, 31, 31, 0.62);
    background: rgba(250, 247, 241, 0.96);
  }
  .am-table { table-layout: auto; width: 100%; }
  .am-table [hidden],
  .am-table tr[hidden] {
    display: none !important;
  }
  .am-table thead th { padding-top: 8px; padding-bottom: 6px; }
  /* Body rows use the existing app's tight row height; the family-header row
     (`.am-fhead td`) needs a more-specific selector to escape this rule. */
  .am-table tbody td { padding-top: 3px; padding-bottom: 3px; }
  .am-col-cluster { width: 1%; }
  .am-table thead th.am-th-cluster { min-width: 140px; text-align: center; vertical-align: bottom; padding: 6px 4px; }
  .am-cluster-link {
    font-family: var(--smallcaps);
    font-size: var(--fs-base);
    letter-spacing: var(--track-label);
    text-transform: lowercase;
    color: var(--ink);
    text-decoration: none;
    border-bottom: 0.5px solid transparent;
    transition: color .12s, border-color .12s;
  }
  .am-cluster-link:hover { color: var(--oxblood); border-bottom-color: var(--oxblood); }
  .am-th-cluster-gpu { font-size: var(--fs-micro); color: var(--ink-3); margin-top: 3px; letter-spacing: 0.02em; font-weight: 400; }
  .am-th-slug { text-align: left; vertical-align: bottom; }
  .am-th-slug-fam { display: block; font-size: var(--fs-base); letter-spacing: var(--track-label); text-transform: lowercase; }
  .am-th-slug-cp {
    display: block;
    margin-top: 2px;
    padding-left: 12px;
    font-family: var(--mono);
    font-size: var(--fs-xs);
    font-weight: 400;
    letter-spacing: 0;
    color: var(--ink-2);
  }

  .am-row .am-slug {
    font-family: var(--mono);
    font-size: var(--fs-xs);
    padding-left: 12px;
    color: var(--ink);
    word-break: break-all;
  }
  .am-slug-link {
    color: inherit;
    text-decoration: none;
    border-bottom: 0.5px solid transparent;
    transition: color .12s, border-color .12s;
  }
  .am-row:hover .am-slug-link {
    color: var(--oxblood);
    border-bottom-color: var(--oxblood);
  }
  .am-row .am-cell {
    text-align: center;
    padding: 3px 0;
    position: relative;
  }

  /* Rows/family-headers hidden because no cluster currently supports them.
     Build-time render applies this from the fixture/live data; the runtime
     refresh re-applies it from current Rootstock state — so the matrix
     reflects live truth even when the build is stale. */
  .am-hidden { display: none; }

  /* Family section header — one TD spanning all columns, hairline above and below.
     `tbody tr.am-fhead td` beats the `tbody td` body-row padding rule above. */
  .am-table tbody tr.am-fhead td {
    border-right: 0;
    background: transparent;
    padding: 12px 8px 5px;
    border-bottom: 0.5px solid var(--rule);
    border-top: 0.5px solid var(--rule);
  }
  .am-fhead-inner {
    display: flex;
    align-items: baseline;
    justify-content: flex-start;
    gap: 16px;
    flex-wrap: wrap;
  }
  /* The table's primary scan target: Source Serif semibold (not IM Fell SC),
     so family names read as the most legible element and the mono checkpoint
     IDs beneath sit clearly subordinate. See "Typography system" in CLAUDE.md. */
  .am-fhead-name {
    font-family: var(--serif);
    font-weight: 600;
    font-size: var(--fs-lg);
    letter-spacing: -0.005em;
    color: var(--ink);
    text-decoration: none;
    border-bottom: 0.5px solid transparent;
    transition: color .12s, border-color .12s;
  }
  .am-fhead-name:hover { color: var(--oxblood); border-bottom-color: var(--oxblood); }


  /* How-to block — full width below the matrix; two-column on desktop. */
  .howto { margin-top: 32px; }
  .howto-head {
    font-family: var(--serif);
    font-size: var(--fs-h3);
    font-weight: 600;
    line-height: 1.2;
    letter-spacing: 0;
    color: var(--ink);
    margin: 0 0 10px;
  }
  .howto-grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 28px;
    align-items: start;
  }
  .howto-prose {
    font-size: var(--fs-xl);
    line-height: 1.5;
    color: var(--ink);
  }
  .howto-prose p { margin: 0 0 8px; }
  .howto-prose p:last-child { margin-bottom: 0; }
  .howto-prose code {
    font-family: var(--mono);
    font-size: 0.86em;
    background: rgba(26, 22, 18, 0.05);
    padding: 1px 4px;
  }
  .howto :global(pre) {
    margin: 0;
    font-family: var(--mono);
    font-size: var(--fs-base);
    line-height: 1.5;
    padding: 10px 12px;
    overflow-x: auto;
    white-space: pre;
    background: rgba(26, 22, 18, 0.035);
    border-left: 1.5px solid var(--oxblood);
  }

  /* Mobile cluster cards (≤720px) — net-new component. */
  .cluster-cards { display: none; margin-top: 22px; }
  .cluster-card {
    display: block;
    text-decoration: none;
    color: var(--ink);
    border-top: 1.5px solid var(--ink);
    border-bottom: 0.5px solid var(--ink);
    padding: 18px 4px 16px;
    background: transparent;
    position: relative;
  }
  .cluster-card + .cluster-card { border-top: 0.5px solid var(--rule); }
  .cluster-card .cc-name {
    font-family: var(--serif);
    font-size: var(--fs-h2);
    line-height: 1.0;
    font-weight: 600;
    letter-spacing: -0.005em;
  }
  .cluster-card .cc-inst {
    font-family: var(--smallcaps);
    font-size: var(--fs-xs);
    letter-spacing: var(--track-label);
    color: var(--ink-2);
    margin-top: 6px;
    display: block;
  }
  .cluster-card .cc-row {
    display: grid;
    grid-template-columns: auto 1fr;
    column-gap: 10px;
    row-gap: 3px;
    margin: 10px 0 0;
    font-size: var(--fs-md);
  }
  .cluster-card .cc-row dt {
    font-family: var(--smallcaps);
    font-size: var(--fs-micro);
    letter-spacing: var(--track-label);
    color: var(--ink-3);
    padding-top: 2px;
    margin: 0;
  }
  .cluster-card .cc-row dd { margin: 0; color: var(--ink); }
  .cluster-card .cc-status {
    margin-top: 12px;
    display: flex;
    flex-wrap: wrap;
    gap: 4px 14px;
    font-size: var(--fs-md);
  }
  .cluster-card .cc-status .it { color: var(--ink-2); }
  .cluster-card .cc-arrow {
    position: absolute;
    right: 4px;
    top: 18px;
    color: var(--oxblood);
    font-family: var(--serif);
    font-size: var(--fs-xl);
  }
  .cluster-card:hover .cc-name { color: var(--oxblood); }

  @media (max-width: 720px) {
    .am-wrap { display: none; }
    .cluster-cards { display: block; }
    .landing-h1 { font-size: 34px; }
    .landing-subtitle { font-size: var(--fs-lg); }
    .landing-cta { font-size: var(--fs-base); gap: 4px 12px; }
    .howto-grid { grid-template-columns: 1fr; gap: 16px; }
    .howto-prose { font-size: var(--fs-lg); }
  }
</style>

<script>
  import { loadLiveDump } from '../lib/rootstock-client';
  import { findVerification, cellStateFor, cellSvg, type CellState } from '../lib/rootstock';


  // Text search composes with the live-data hide: search hides rows that
  // don't match the query via the `hidden` attribute, but never *un*hides a
  // row that the live script has marked `am-hidden` (no current support).
  // Family head shows iff at least one row is both search-matched and
  // live-supported.
  const searchInput = document.querySelector<HTMLInputElement>('[data-am-search]');
  const familyHeads = Array.from(document.querySelectorAll<HTMLTableRowElement>('.am-fhead[data-am-family]'));
  const dataRows = Array.from(document.querySelectorAll<HTMLTableRowElement>('.am-row[data-am-family]'));

  const applySearch = () => {
    const q = searchInput?.value.trim().toLowerCase() ?? '';
    familyHeads.forEach((head) => {
      const family = head.dataset.amFamily;
      let hasVisibleRow = false;
      dataRows
        .filter((row) => row.dataset.amFamily === family)
        .forEach((row) => {
          const textMatch = !q || (row.dataset.amSearch ?? '').includes(q);
          row.hidden = !textMatch;
          if (textMatch && !row.classList.contains('am-hidden')) hasVisibleRow = true;
        });
      head.hidden = !hasVisibleRow;
    });
  };

  searchInput?.addEventListener('input', applySearch);
  applySearch();

  // Re-derive visibility purely from live data. Whatever the build baked in
  // gets overwritten — that's the point. A stale build can't strand rows.
  loadLiveDump()
    .then((dump) => {
      const familySupportedCount: Record<string, number> = {};
      const perCluster: Record<string, { verified: number; lapsed: number; na: number }> = {};
      const rows = document.querySelectorAll<HTMLElement>('[data-rs-row]');
      rows.forEach((tr) => {
        const tdCells = tr.querySelectorAll<HTMLElement>('[data-rs-cell]');
        const cellInfo: Array<{ cluster: string; state: CellState }> = [];
        tdCells.forEach((td) => {
          const [cluster, checkpoint] = td.dataset.rsCell!.split(':');
          cellInfo.push({ cluster, state: cellStateFor(findVerification(dump, cluster, checkpoint)) });
        });
        const states = cellInfo.map((x) => x.state);
        const allNa = states.every((s) => s === 'na');
        const famId = tr.dataset.rsFamilyId ?? '';
        familySupportedCount[famId] = (familySupportedCount[famId] ?? 0) + (allNa ? 0 : 1);
        tr.classList.toggle('am-hidden', allNa);
        if (!allNa) {
          for (const { cluster, state } of cellInfo) {
            (perCluster[cluster] ??= { verified: 0, lapsed: 0, na: 0 })[state]++;
          }
          tdCells.forEach((td, i) => { td.innerHTML = cellSvg(states[i]); });
        }
      });
      document.querySelectorAll<HTMLElement>('[data-rs-cluster-count]').forEach((el) => {
        const [cluster, metric] = el.dataset.rsClusterCount!.split(':') as [string, 'verified' | 'lapsed' | 'na'];
        el.textContent = String(perCluster[cluster]?.[metric] ?? 0);
      });
      document.querySelectorAll<HTMLElement>('[data-rs-family]').forEach((tr) => {
        const famId = tr.dataset.rsFamily ?? '';
        tr.classList.toggle('am-hidden', (familySupportedCount[famId] ?? 0) === 0);
      });
      applySearch();
    })
    .catch((err) => console.warn('Rootstock live refresh failed', err));
</script>
