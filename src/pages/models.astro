---
import { getCollection, getEntry } from 'astro:content';
import Page from '../layouts/Page.astro';
import SimilarityTree from '../components/SimilarityTree.astro';
import { url } from '../lib/url';
import { yearOf } from '../lib/format';

const allModels = await getCollection('models');

// Catalogue rail — every model, most-recent-first, name + year only.
const enriched = await Promise.all(
  allModels.map(async (m) => {
    let resolvedDate = m.data.releaseDate ?? null;
    if (!resolvedDate) {
      for (const ref of m.data.paperRefs) {
        const p = await getEntry('papers', ref.id);
        if (p?.data.published) { resolvedDate = p.data.published; break; }
      }
    }
    return { model: m, resolvedDate, year: yearOf(resolvedDate) };
  }),
);
const models = enriched.sort((a, b) => {
  if (!a.resolvedDate && !b.resolvedDate) return a.model.data.name.localeCompare(b.model.data.name);
  if (!a.resolvedDate) return 1;
  if (!b.resolvedDate) return -1;
  return b.resolvedDate.localeCompare(a.resolvedDate);
});

// Architecture Families — full-width below the split (same data as /architectures).
const FAMILY_ORDER = ['equivariant', 'ace', 'mpnn', 'vanilla', 'earlier', 'attention'];
const families = (await getCollection('architectures')).sort(
  (a, b) => FAMILY_ORDER.indexOf(a.id) - FAMILY_ORDER.indexOf(b.id),
);
const modelsByFamily: Record<string, Array<{ id: string; name: string }>> = {};
for (const f of families) {
  modelsByFamily[f.id] = allModels
    .filter((m) => m.data.families.some((ref) => ref.id === f.id))
    .map((m) => ({ id: m.id, name: m.data.name }))
    .sort((a, b) => a.name.localeCompare(b.name));
}
const familyCards = families.filter((f) => modelsByFamily[f.id].length > 0);
---

<Page title="Models — Garden's Almanac" wide>
  <div class="models-page" data-view="year">
    <div class="models-titlerow">
      <h1 class="models-h1">Models</h1>
      <div class="models-viewswitch" role="tablist" aria-label="View">
        <button type="button" class="models-viewbtn" data-view-btn="year" aria-pressed="true">By year</button>
        <button type="button" class="models-viewbtn" data-view-btn="embed" aria-pressed="false">By embedding similarity</button>
      </div>
    </div>

    <section class="models-standfirst">
      <p class="models-lede">
        <b>Each dot in the map is a model.</b> They were all shown the same structures, and the tree
        compares the internal representations they built — not their predictions. Models that picture
        matter alike sit on nearby branches; color marks the data each one learned from.
      </p>
      <div class="models-key">
        <div class="models-key-row">
          <svg width="58" height="16" viewBox="0 0 58 16" aria-hidden="true">
            <line x1="6" y1="8" x2="30" y2="8" stroke="var(--ink)" stroke-width="1.5" stroke-linecap="round" />
            <circle cx="6" cy="8" r="3.4" fill="var(--ink-2)" /><circle cx="30" cy="8" r="3.4" fill="var(--ink-2)" />
          </svg>
          <span><b>Short branch</b> — the two models build almost the same representation.</span>
        </div>
        <div class="models-key-row">
          <svg width="58" height="16" viewBox="0 0 58 16" aria-hidden="true">
            <line x1="6" y1="8" x2="46" y2="8" stroke="var(--ink)" stroke-width="1.5" stroke-linecap="round" />
            <circle cx="6" cy="8" r="3.4" fill="var(--ink-2)" /><circle cx="46" cy="8" r="3.8" fill="var(--oxblood)" />
          </svg>
          <span><b>Long branch</b> — this model represents matter unlike the rest.</span>
        </div>
      </div>
    </section>

    <section class="models-split">
      <div class="models-rail">
        <p class="it models-rail-cap">By publication year</p>
        {models.map(({ model: m, year }) => (
          <div class="models-rail-row">
            <a class="ink-link it models-rail-name" href={url(`/model/${m.id}`)}>{m.data.name}</a>
            <span class="mono models-rail-year">{year ?? '—'}</span>
          </div>
        ))}
      </div>

      <div class="models-divider" aria-hidden="true"></div>

      <div class="models-mapcol">
        <SimilarityTree />
      </div>
    </section>

    {familyCards.length > 0 && (
      <section class="models-families">
        <hr class="models-families-rule" />
        <h2 class="models-families-h2">Architecture Families</h2>
        <div class="models-families-grid">
          {familyCards.map((f) => (
            <div class="models-family">
              <h3 class="models-family-h3">{f.data.name}</h3>
              <p class="models-family-brief">{f.data.descriptor}</p>
              <div class="models-family-models">
                <span class="sc models-family-k">Models</span>
                {modelsByFamily[f.id].map((m) => (
                  <>
                    <span class="models-family-sep" aria-hidden="true">·</span>
                    <a class="ink-link it" href={url(`/model/${m.id}`)}>{m.name}</a>
                  </>
                ))}
              </div>
            </div>
          ))}
        </div>
      </section>
    )}
  </div>
</Page>

<style>
  .models-titlerow {
    display: flex; align-items: flex-end; justify-content: space-between;
    gap: 20px; flex-wrap: wrap;
  }
  .models-h1 {
    font-family: var(--serif); font-size: 44px; font-weight: 600;
    line-height: 1; letter-spacing: -0.01em; margin: 0;
  }

  /* View switch — only shown when the split collapses (narrow). */
  .models-viewswitch { display: none; gap: 0 22px; align-items: baseline; }
  .models-viewbtn {
    font-family: var(--smallcaps); text-transform: lowercase; font-size: 14px;
    letter-spacing: 0.04em; background: transparent; border: 0;
    border-bottom: 1.5px solid transparent; padding: 3px 0; cursor: pointer;
    line-height: 1.1; color: var(--ink-3);
  }
  .models-page[data-view="year"] .models-viewbtn[data-view-btn="year"],
  .models-page[data-view="embed"] .models-viewbtn[data-view-btn="embed"] {
    color: var(--oxblood); border-bottom-color: var(--oxblood);
  }

  .models-standfirst {
    display: grid; grid-template-columns: minmax(0, 1fr) auto;
    gap: 24px 44px; align-items: center;
    border-top: 1.5px solid var(--ink); border-bottom: 0.5px solid var(--ink);
    padding: 14px 0 16px; margin: 16px 0 24px;
  }
  .models-lede { margin: 0; font-size: 16px; line-height: 1.5; max-width: 64ch; }
  .models-lede b { font-weight: 600; }
  .models-key { display: flex; flex-direction: column; gap: 8px; }
  .models-key-row { display: flex; align-items: center; gap: 10px; font-size: 11.5px; line-height: 1.3; color: var(--ink-2); }
  .models-key-row b { color: var(--ink); font-weight: 600; }

  .models-split { display: flex; align-items: flex-start; }
  .models-rail { flex: 0 0 196px; min-width: 168px; padding-right: 4px; }
  .models-rail-cap { font-size: 13.5px; color: var(--ink-2); margin: 0 0 10px; line-height: 1.2; }
  .models-rail-row {
    display: flex; align-items: baseline; justify-content: space-between;
    gap: 10px; padding: 6px 1px; border-bottom: 0.5px solid var(--rule-soft);
  }
  .models-rail-name { font-size: 14px; min-width: 0; }
  .models-rail-year {
    font-size: 11.5px; color: var(--ink-3); flex: 0 0 auto;
    font-variant-numeric: tabular-nums;
  }
  .models-divider { flex: 0 0 auto; align-self: stretch; border-left: 0.5px solid var(--rule-soft); margin: 0 40px; }
  .models-mapcol { flex: 1 1 auto; min-width: 0; }

  .models-families { margin-top: 48px; }
  .models-families-rule {
    border: 0; border-top: 1.5px solid var(--ink); border-bottom: 0.5px solid var(--ink);
    height: 3px; margin: 0 0 12px;
  }
  .models-families-h2 {
    font-family: var(--serif); font-size: 30px; font-weight: 600;
    line-height: 1.04; letter-spacing: -0.008em; margin: 0 0 16px;
  }
  .models-families-grid { display: grid; grid-template-columns: repeat(auto-fit, minmax(440px, 1fr)); gap: 0 44px; }
  .models-family { padding: 16px 0 18px; border-top: 0.5px solid var(--rule); }
  .models-family-h3 {
    font-family: var(--serif); font-size: 19px; font-weight: 600;
    line-height: 1.15; letter-spacing: -0.003em; margin: 0;
  }
  .models-family-brief { font-size: 13px; line-height: 1.5; color: var(--ink); margin: 6px 0 0; }
  .models-family-models { margin-top: 10px; font-size: 12.5px; line-height: 1.7; }
  .models-family-k {
    font-size: 10.5px; letter-spacing: 0.10em; color: var(--ink-3); margin-right: 4px;
  }
  .models-family-sep { color: var(--ink-3); margin: 0 6px 0 7px; }

  /* Collapse to a single column with a view toggle on narrow screens. */
  @media (max-width: 720px) {
    .models-viewswitch { display: flex; }
    .models-standfirst { grid-template-columns: 1fr; gap: 14px; }
    .models-split { display: block; }
    .models-divider { display: none; }
    .models-page[data-view="year"] .models-mapcol { display: none; }
    .models-page[data-view="embed"] .models-rail { display: none; }
    .models-rail, .models-mapcol { width: 100%; }
    .models-families-grid { grid-template-columns: 1fr; }
  }
</style>

<script>
  const page = document.querySelector<HTMLElement>('.models-page');
  if (page) {
    const setView = (v: 'year' | 'embed', push: boolean) => {
      page.dataset.view = v;
      page.querySelectorAll<HTMLButtonElement>('.models-viewbtn').forEach((b) =>
        b.setAttribute('aria-pressed', String(b.dataset.viewBtn === v)),
      );
      if (push) {
        const p = new URLSearchParams(location.search);
        if (v === 'embed') p.set('view', 'embedding'); else p.delete('view');
        const qs = p.toString();
        history.replaceState(null, '', location.pathname + (qs ? '?' + qs : '') + location.hash);
      }
    };
    if (new URLSearchParams(location.search).get('view') === 'embedding') setView('embed', false);
    page.querySelectorAll<HTMLButtonElement>('.models-viewbtn').forEach((b) =>
      b.addEventListener('click', () => setView(b.dataset.viewBtn as 'year' | 'embed', true)),
    );
  }
</script>
