---
import { getCollection, getEntry } from 'astro:content';
import Page from '../layouts/Page.astro';
import MapStage from '../components/MapStage.astro';
import { url } from '../lib/url';
import { displayParams } from '../lib/params';
import { yearOf } from '../lib/format';

const allModels = await getCollection('models');
const families = await getCollection('architectures');
const familyName = (id: string) => families.find((f) => f.id === id)?.data.name ?? id;

const enriched = await Promise.all(
  allModels.map(async (m) => {
    let resolvedDate = m.data.releaseDate ?? null;
    if (!resolvedDate) {
      for (const ref of m.data.paperRefs) {
        const p = await getEntry('papers', ref.id);
        if (p?.data.published) {
          resolvedDate = p.data.published;
          break;
        }
      }
    }
    return { model: m, resolvedDate, year: yearOf(resolvedDate) };
  }),
);

const models = enriched.sort((a, b) => {
  if (!a.resolvedDate && !b.resolvedDate) return a.model.data.name.localeCompare(b.model.data.name);
  if (!a.resolvedDate) return 1;
  if (!b.resolvedDate) return -1;
  return b.resolvedDate.localeCompare(a.resolvedDate);
});

// Embedded similarity map — same set of layouts as the former /map page.
const DISPLAY_ORDER = ['map-omol25', 'map-omat24', 'map-qm9', 'map-salex'];
const allLayouts = await getCollection('embeddings');
const layouts = DISPLAY_ORDER
  .map((id) => allLayouts.find((e) => e.id === id))
  .filter((e): e is NonNullable<typeof e> => Boolean(e));
if (layouts.length === 0) {
  throw new Error('no embeddings/* layouts found — run almanac_embeddings/export_layouts.py');
}
const tabs = layouts.map((l, i) => ({
  id: l.id,
  inputId: `ds-${l.id}`,
  label: l.data.dataset,
  layout: l,
  isFirst: i === 0,
}));
---
<Page title="Models — Garden's Almanac">
  <header class="models-head">
    <h1 class="models-h1">Models</h1>
    <p class="it models-subtitle">
      All {models.length} catalogued models, most recent first. Click any name for the detail page.
    </p>
  </header>

  <section class="models-list">
    <table class="almanac" style="font-size: 13px;">
      <thead>
        <tr>
          <th>Name</th>
          <th>Family</th>
          <th style="text-align: right; width: 90px;">Params</th>
          <th style="text-align: right; width: 70px;">Year</th>
          <th style="width: 24px;" aria-hidden="true"></th>
        </tr>
      </thead>
      <tbody>
        {models.map(({ model: m, year }) => (
          <tr>
            <td><a class="ink-link it" href={url(`/model/${m.id}`)}>{m.data.name}</a></td>
            <td class="sc" style="font-size: 11px;">{familyName(m.data.families[0].id)}</td>
            <td style="text-align: right; font-variant-numeric: tabular-nums;">{displayParams(m.data.checkpoints)}</td>
            <td style="text-align: right; font-variant-numeric: tabular-nums;">{year ?? '—'}</td>
            <td style="text-align: right; color: var(--ink-3);" aria-hidden="true">→</td>
          </tr>
        ))}
      </tbody>
    </table>
  </section>

  <section class="models-map">
    <hr class="hairline" />
    <header class="models-map-head">
      <div>
        <h2 class="models-map-h2">Embedding similarity map</h2>
        <p class="it models-map-caption">
          Proximity encodes representational similarity (CKNNA, <span class="mono">k = 25</span>);
          the axes themselves carry no independent meaning.
        </p>
      </div>
      <fieldset class="map-toggle">
        <legend class="sc map-toggle-legend">Reference dataset</legend>
        <div class="map-toggle-tabs">
          {tabs.map((t) => (
            <>
              <input
                class="map-toggle-input"
                type="radio"
                name="ds"
                id={t.inputId}
                value={t.id}
                data-ds={t.label}
                checked={t.isFirst}
              />
              <label for={t.inputId} class="sc map-toggle-tab">{t.label}</label>
            </>
          ))}
        </div>
      </fieldset>
    </header>

    <div class="map-stages">
      {tabs.map((t) => (
        <MapStage layout={t.layout} active={t.isFirst} />
      ))}
    </div>
  </section>
</Page>

<style>
  .models-head { margin-bottom: 18px; }
  .models-h1 {
    font-family: var(--serif);
    font-size: 44px;
    font-weight: 600;
    line-height: 1.02;
    letter-spacing: -0.01em;
    margin: 0;
  }
  .models-subtitle {
    color: var(--ink-2);
    font-size: 14px;
    margin: 6px 0 0;
  }

  .models-map { margin-top: 36px; }
  .models-map-head {
    display: flex;
    align-items: flex-end;
    justify-content: space-between;
    gap: 24px;
    flex-wrap: wrap;
    margin: 18px 0 12px;
  }
  .models-map-h2 {
    font-family: var(--serif);
    font-size: 22px;
    font-weight: 600;
    line-height: 1.1;
    letter-spacing: -0.005em;
    margin: 0;
  }
  .models-map-caption {
    color: var(--ink-2);
    font-size: 13px;
    line-height: 1.45;
    max-width: 52ch;
    margin: 4px 0 0;
  }

  /* Reference-dataset toggle — same visual as the old /map page. */
  .map-toggle {
    border: none;
    margin: 0;
    padding: 0;
    flex: 0 0 auto;
    margin-left: auto;
  }
  .map-toggle-legend {
    display: block;
    font-size: 10.5px;
    letter-spacing: 0.10em;
    color: var(--ink-2);
    margin: 0 0 6px;
    padding: 0;
    text-align: right;
  }
  .map-toggle-tabs {
    display: flex;
    align-items: baseline;
    gap: 0;
    border-top: 0.5px solid var(--ink);
    border-bottom: 0.5px solid var(--ink);
    padding: 4px 0 3px;
  }
  .map-toggle-input {
    position: absolute;
    opacity: 0;
    pointer-events: none;
    width: 0;
    height: 0;
  }
  .map-toggle-tab {
    display: inline-block;
    font-size: 12px;
    letter-spacing: 0.14em;
    color: var(--ink-2);
    padding: 4px 12px 4px;
    cursor: pointer;
    user-select: none;
    border-left: 0.5px solid var(--ink-2);
    transition: color 0.12s;
  }
  .map-toggle-tab:first-of-type { border-left: none; }
  .map-toggle-tab:hover { color: var(--ink); }
  .map-toggle-input:checked + .map-toggle-tab {
    color: var(--paper);
    background: var(--ink);
  }
  .map-toggle-input:focus-visible + .map-toggle-tab {
    outline: 1px dotted var(--ink);
    outline-offset: 2px;
  }
</style>

<script>
  const inputs = document.querySelectorAll<HTMLInputElement>('.map-toggle-input');
  const stages = document.querySelectorAll<HTMLElement>('.map-stage');
  const show = (ds: string | undefined) => {
    if (!ds) return;
    stages.forEach((s) => s.classList.toggle('is-active', s.dataset.ds === ds));
  };
  inputs.forEach((input) =>
    input.addEventListener('change', () => {
      if (input.checked) show(input.dataset.ds);
    }),
  );
</script>
